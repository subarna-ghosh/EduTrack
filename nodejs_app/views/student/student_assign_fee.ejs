<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Assign Fee</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
    />

    <style>
      body {
        background: #f4f6f9;
      }

      .form-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 0.15rem 1.75rem rgba(58, 59, 69, 0.15);
      }

      .page-title {
        font-weight: 700;
        color: #343a40;
      }

      .form-label {
        font-weight: 600;
      }

      .info-box {
        background: #e7f1ff;
        border-left: 4px solid #0d6efd;
        padding: 15px;
        border-radius: 10px;
        margin-bottom: 20px;
      }
    </style>
  </head>

  <body>
    <div class="container py-5">
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <div class="card form-card">
            <div class="card-header bg-white py-3">
              <h3 class="page-title mb-0">Assign Student Fee</h3>
            </div>

            <div class="card-body p-4">
              <div class="info-box">
                <strong>Note:</strong>

                Assign the total course fee for the selected student. Paid
                amount will start from ₹0.
              </div>

              <form action="#" method="POST">
                <!-- Student -->

                <div class="mb-3">
                  <label class="form-label"> Select Student </label>

                  <select name="studentId" class="form-select" required>
                    <option value="">Select Student</option>

                    <option value="1">Subarna Ghosh</option>

                    <option value="2">Rahul Das</option>

                    <option value="3">Priya Roy</option>
                  </select>
                </div>

                <!-- Total Fee -->

                <div class="mb-3">
                  <label class="form-label"> Total Course Fee </label>

                  <input
                    type="number"
                    name="totalFee"
                    class="form-control"
                    placeholder="Enter total fee"
                    required
                  />
                </div>

                <!-- Course -->

                <div class="mb-3">
                  <label class="form-label"> Course Name </label>

                  <input
                    type="text"
                    class="form-control"
                    placeholder="Node.js Complete"
                    readonly
                  />
                </div>

                <!-- Paid Amount -->

                <div class="mb-3">
                  <label class="form-label"> Initial Paid Amount </label>

                  <input
                    type="number"
                    class="form-control"
                    value="0"
                    readonly
                  />
                </div>

                <!-- Buttons -->

                <div class="d-flex gap-3">
                  <button type="submit" class="btn btn-primary">
                    <i class="fa-solid fa-money-bill-wave me-2"></i>
                    Assign Fee
                  </button>

                  <a href="#" class="btn btn-secondary">
                    <i class="fa-solid fa-arrow-left me-2"></i>
                    Back
                  </a>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
