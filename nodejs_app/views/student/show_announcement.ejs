<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Student Announcements</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
    />
    <link rel="stylesheet" href="/assets/css/show_announcement_student.css">
  </head>

  <body>
    <div class="container py-5">
      <!-- Header -->

      <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
          <h2 class="page-title mb-1">Announcements</h2>
          <p class="text-muted mb-0">
            Stay updated with the latest academy notices and updates.
          </p>
        </div>

        <a href="/web/view/student/dashboard" class="dashboard-btn">
          <i class="fa-solid fa-arrow-left me-2"></i>
          Dashboard
        </a>
      </div>

      <!-- Upcoming -->

      <h4 class="section-title">Upcoming Announcements</h4>

      <div class="empty-box mb-5">
        <i class="fa-solid fa-bullhorn"></i>

        <h5>No urgent announcements</h5>

        <p class="text-muted mb-0">You're all caught up.</p>
      </div>

      <!-- All Announcements -->

      <h4 class="section-title">All Announcements</h4>

      <!-- Card 1 -->
       <%announcementsMade.forEach((val)=>{%>
      <div class="card announcement-card">
        <div class="d-flex">
          <div class="date-box">
            <h2><%= new Date(val.createdAt).toLocaleDateString("en-GB", { day: "numeric" }) %></h2>
            <span><%= new Date(val.createdAt).toLocaleDateString("en-GB", { month: "short" }).toUpperCase() %></span>
          </div>

          <div class="card-content flex-grow-1">
            <div class="d-flex justify-content-between">
              <h5 class="announcement-title"><%=val.title%></h5>

              <span class="badge bg-danger"> Important </span>
            </div>

            <p class="announcement-desc">
              <%=val.description%>
            </p>

            <div class="card-footer-custom">
              <span class="location">
                <i class="fa-regular fa-calendar me-2"></i>
                <%=new Date(val.createdAt).toLocaleDateString("en-GB")%>
              </span>
            </div>
          </div>
        </div>
      </div>
      <%})%>

    </div>
  </body>
</html>
