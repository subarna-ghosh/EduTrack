<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>My Profile</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
    />

    <style>
      body {
        background: #f4f6f9;
      }

      .profile-card {
        border: none;
        border-radius: 18px;
        box-shadow: 0 0.15rem 1.75rem rgba(58, 59, 69, 0.15);
      }

      .profile-header {
        background: linear-gradient(135deg, #0d6efd, #4f8cff);
        border-radius: 18px 18px 0 0;
        color: white;
        padding: 40px;
      }

      .profile-image {
        width: 140px;
        height: 140px;
        border-radius: 50%;
        object-fit: cover;
        border: 5px solid white;
        background: white;
      }

      .student-name {
        font-size: 30px;
        font-weight: 700;
      }

      .student-code {
        opacity: 0.9;
      }

      .info-card {
        background: #fff;
        border: 1px solid #e9ecef;
        border-radius: 12px;
        padding: 20px;
        height: 100%;
      }

      .info-label {
        color: #6c757d;
        font-size: 14px;
        margin-bottom: 6px;
      }

      .info-value {
        font-size: 16px;
        font-weight: 600;
        color: #212529;
      }

      .section-title {
        font-weight: 700;
        color: #343a40;
      }

      .btn-custom {
        height: 45px;
      }
    </style>
  </head>

  <body>
    <div class="container py-5">
      <!-- Top Header -->

      <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
          <h2 class="section-title mb-1">My Profile</h2>

          <p class="text-muted mb-0">
            View and manage your account information.
          </p>
        </div>

        <a href="/web/view/student/dashboard" class="btn btn-secondary">
          ← Back to Dashboard
        </a>
        
      </div>

      <!-- Profile Card -->

      <div class="card profile-card">
        <!-- Header -->

        <div class="profile-header">
          <div class="row align-items-center">
            <div class="col-lg-2 text-center">
              <img
                src="<%=myProfile[0].profileImage%>"
                class="profile-image"
                alt="Profile"
              />
            </div>

            <div class="col-lg-10">
              <h2 class="student-name mb-2"><%=myProfile[0].userInfo.name%></h2>
              <p class="student-code mb-2">Student Code: <%=myProfile[0].studentCode%></p>
              <span class="badge bg-success px-3 py-2"><%=myProfile[0].status%></span>
            </div>
          </div>
        </div>

        <!-- Body -->

        <div class="card-body p-4">
          <div class="row g-4">
            <!-- Email -->

            <div class="col-md-6">
              <div class="info-card">
                <div class="info-label">Email Address</div>
                <div class="info-value"><%=myProfile[0].userInfo.email%></div>
              </div>
            </div>

            <!-- Phone -->

            <div class="col-md-6">
              <div class="info-card">
                <div class="info-label">Phone Number</div>
                <div class="info-value"><%=myProfile[0].phone%></div>
              </div>
            </div>

            <!-- Batch -->

            <div class="col-md-6">
              <div class="info-card">
                <div class="info-label">Batch</div>
                <div class="info-value"><%=myProfile[0].batchInfo.batchName%></div>
              </div>
            </div>

            <!-- Status -->

            <div class="col-md-6">
              <div class="info-card">
                <div class="info-label">Account Status</div>
                <div class="info-value"><%=myProfile[0].status%></div>
              </div>
            </div>

            <!-- Admission Date -->

            <div class="col-md-6">
              <div class="info-card">
                <div class="info-label">Admission Date</div>
                <div class="info-value"><%=new Date(myProfile[0].createdAt).toLocaleDateString("en-GB")%></div>
              </div>
            </div>

            <!-- Last Updated -->

            <div class="col-md-6">
              <div class="info-card">
                <div class="info-label">Last Updated</div>
                <div class="info-value"><%=new Date(myProfile[0].updatedAt).toLocaleDateString("en-GB")%></div>
              </div>
            </div>

            <!-- Address -->

            <div class="col-12">
              <div class="info-card">
                <div class="info-label">Address</div>
                <div class="info-value"><%=myProfile[0].address%></div>
              </div>
            </div>
          </div>

          <!-- Buttons -->

          <div class="d-flex gap-3 mt-4">
            <a href="/web/view/edit/my/student/profile" class="btn btn-primary btn-custom">
              <i class="fa-solid fa-user-pen me-2"></i>
              Edit Profile
            </a>

            <a href="/web/view/change/my/password" class="btn btn-warning btn-custom">
              <i class="fa-solid fa-key me-2"></i>
              Change Password
            </a>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
