<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Student Pay Now</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
    />
    <link rel="stylesheet" href="/assets/css/student_pay_now.css">
  </head>

  <body>
    <div class="container py-5">
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <div class="card payment-card">
            <div class="card-header bg-white py-3">
              <h3 class="page-title mb-0">Pay Course Fee</h3>
            </div>

            <div class="card-body p-4">
              <!-- Fee Summary -->

              <div class="summary-box">
                <h5 class="mb-4">Payment Summary</h5>

                <div class="summary-item">
                  <span>Total Course Fee</span>

                  <span class="amount"> ₹50,000 </span>
                </div>

                <div class="summary-item">
                  <span>Amount Paid</span>

                  <span class="amount paid"> ₹35,000 </span>
                </div>

                <div class="summary-item">
                  <span>Remaining Due</span>

                  <span class="amount due"> ₹15,000 </span>
                </div>
              </div>

              <!-- Form -->

              <form action="#" method="POST">
                <!-- Amount -->

                <div class="mb-4">
                  <label class="form-label"> Amount To Pay </label>

                  <input
                    type="number"
                    class="form-control"
                    placeholder="Enter amount"
                    required
                  />
                </div>

                <!-- Payment Method -->

                <div class="mb-4">
                  <label class="form-label d-block mb-3">
                    Select Payment Method
                  </label>

                  <div class="row g-3">
                    <div class="col-md-6">
                      <label class="method-card w-100">
                        <input
                          type="radio"
                          name="paymentMethod"
                          value="upi"
                          class="form-check-input me-2"
                          required
                        />

                        <i class="fa-solid fa-mobile-screen-button me-2"></i>

                        UPI
                      </label>
                    </div>

                    <div class="col-md-6">
                      <label class="method-card w-100">
                        <input
                          type="radio"
                          name="paymentMethod"
                          value="card"
                          class="form-check-input me-2"
                        />

                        <i class="fa-solid fa-credit-card me-2"></i>

                        Debit / Credit Card
                      </label>
                    </div>

                    <div class="col-md-6">
                      <label class="method-card w-100">
                        <input
                          type="radio"
                          name="paymentMethod"
                          value="bank"
                          class="form-check-input me-2"
                        />

                        <i class="fa-solid fa-building-columns me-2"></i>

                        Bank Transfer
                      </label>
                    </div>

                    <div class="col-md-6">
                      <label class="method-card w-100">
                        <input
                          type="radio"
                          name="paymentMethod"
                          value="cash"
                          class="form-check-input me-2"
                        />

                        <i class="fa-solid fa-money-bill-wave me-2"></i>

                        Cash
                      </label>
                    </div>
                  </div>
                </div>

                <!-- Information Box -->

                <div class="payment-info">
                  <h6>
                    <i class="fa-solid fa-circle-info me-2"></i>
                    Payment Information
                  </h6>

                  <p>
                    • UPI, Card and Bank payments are verified automatically.
                  </p>

                  <p>• Cash payments require admin approval.</p>

                  <p>• Payment status can be viewed from Payment History.</p>
                </div>

                <!-- Buttons -->

                <div class="d-flex gap-3 mt-4">
                  <button type="submit" class="btn btn-success btn-pay">
                    <i class="fa-solid fa-credit-card me-2"></i>

                    Pay Now
                  </button>

                  <a href="/web/view/student/dashboard" class="btn btn-secondary btn-pay">
                    <i class="fa-solid fa-arrow-left me-2"></i>

                    Back
                  </a>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
