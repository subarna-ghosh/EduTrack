<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>My Batch</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
    />

    <style>
      body {
        background: #f4f6f9;
      }

      .page-title {
        font-weight: 700;
        margin-bottom: 30px;
      }

      .card-box {
        border: none;
        border-radius: 14px;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
      }

      .batch-info {
        background: #0d6efd;
        color: #fff;
      }

      .batch-info h5 {
        font-weight: 700;
      }

      .info-item {
        margin-bottom: 15px;
      }

      .today-class {
        border-left: 5px solid #198754;
      }

      .holiday {
        border-left: 5px solid #ffc107;
      }

      .table th {
        background: #0d6efd;
        color: #fff;
      }

      .join-btn {
        font-weight: 600;
      }
    </style>
  </head>

  <body>
    <div class="container py-5">
      <h2 class="page-title">My Batch</h2>

      <div class="row g-4">
        <!-- Batch Information -->

        <div class="col-lg-4">
          <div class="card card-box batch-info">
            <div class="card-body">
              <h5>Batch Information</h5>

              <hr />

              <div class="info-item">
                <strong>Course</strong>

                <br />

                MERN Stack Development
              </div>

              <div class="info-item">
                <strong>Batch</strong>

                <br />

                MERN - A
              </div>

              <div class="info-item">
                <strong>Faculty</strong>

                <br />

                Rahul Sharma
              </div>

              <div class="info-item">
                <strong>Batch Timing</strong>

                <br />

                10:00 AM - 12:00 PM
              </div>
            </div>
          </div>
        </div>

        <!-- Today's Class -->

        <div class="col-lg-8">
          <div class="card card-box today-class">
            <div class="card-header bg-white">
              <h5 class="mb-0">Today's Class</h5>
            </div>

            <div class="card-body">
              <h4>Authentication using JWT</h4>

              <p>
                Today's topic covers JWT authentication, login flow and
                middleware implementation.
              </p>

              <div class="row">
                <div class="col-md-4">
                  <strong>Faculty</strong>

                  <br />

                  Rahul Sharma
                </div>

                <div class="col-md-4">
                  <strong>Time</strong>

                  <br />

                  10:00 AM - 12:00 PM
                </div>

                <div class="col-md-4">
                  <strong>Status</strong>

                  <br />

                  <span class="badge bg-success"> Live Today </span>
                </div>
              </div>

              <hr />

              <a href="#" class="btn btn-success join-btn">
                <i class="fa-solid fa-video me-2"></i>

                Join Class
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Holiday Card -->

      <!-- Replace Today's Class card with this card whenever
    no schedule is available today. -->

      <!-- <div class="card card-box holiday mt-4">

        <div class="card-body text-center">

            <h3>

                No classes today!

            </h3>

            <p class="mb-0">

                There are no classes scheduled for today.

                Enjoy your day and we'll see you
                in the next class.

            </p>

        </div>

    </div> -->

      <!-- Upcoming Classes -->

      <div class="card card-box mt-4">
        <div class="card-header bg-white">
          <h5 class="mb-0">Upcoming Classes</h5>
        </div>

        <div class="card-body">
          <div class="table-responsive">
            <table class="table table-bordered table-hover">
              <thead>
                <tr>
                  <th>Day</th>

                  <th>Topic</th>

                  <th>Faculty</th>

                  <th>Time</th>
                </tr>
              </thead>

              <tbody>
                <tr>
                  <td>Monday</td>

                  <td>Authentication using JWT</td>

                  <td>Rahul Sharma</td>

                  <td>10:00 AM - 12:00 PM</td>
                </tr>

                <tr>
                  <td>Wednesday</td>

                  <td>React Components</td>

                  <td>Rahul Sharma</td>

                  <td>10:00 AM - 12:00 PM</td>
                </tr>

                <tr>
                  <td>Friday</td>

                  <td>React Router</td>

                  <td>Rahul Sharma</td>

                  <td>10:00 AM - 12:00 PM</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
