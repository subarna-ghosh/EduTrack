<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>My Batch</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
    />
    <link rel="stylesheet" href="/assets/css/sidebar.css" />
    <link rel="stylesheet" href="/assets/css/student_navbar.css" />

    <style>
      body {
        background: #f4f6f9;
      }

      .page-title {
        font-weight: 700;
        margin-bottom: 30px;
      }

      .card-box {
        border: none;
        border-radius: 14px;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
      }

      .batch-info {
        background: #0d6efd;
        color: #fff;
      }

      .batch-info h5 {
        font-weight: 700;
      }

      .info-item {
        margin-bottom: 15px;
      }

      .today-class {
        border-left: 5px solid #198754;
      }

      .holiday {
        border-left: 5px solid #ffc107;
      }

      .table th {
        background: #0d6efd;
        color: #fff;
      }

      .join-btn {
        font-weight: 600;
      }
    </style>
  </head>

  <body>
    <div class="container-fluid">
      <div class="row">
        <!-- SIDEBAR -->
        <%-include('../layouts/student_sidebar')%>
        <div class="col-lg-10 main-content">
          <!-- TOPBAR -->
          <%-include('../layouts/student_navbar')%>
          <div>

      <div class="row g-4">
        <!-- Batch Information -->

        <div class="col-lg-4">
          <div class="card card-box batch-info">
            <div class="card-body">
              <h5>Batch Information</h5>

              <hr />

              <div class="info-item">
                <strong>Course</strong>
                <br />
                <%=showSchedule[0].courseInfo.courseName%>
              </div>

              <div class="info-item">
                <strong>Batch</strong>
                <br />
                <%=showSchedule[0].batchInfo.batchName%>
              </div>

              <div class="info-item">
                <strong>Faculty</strong>
                <br />
                <%=showSchedule[0].facultyUser.name%>
              </div>

            </div>
          </div>
        </div>

        <!-- Today's Class -->
        <%if(todayClass){%>
        <div class="col-lg-8">
          <div class="card card-box today-class">
            <div class="card-header bg-white">
              <h5 class="mb-0">Today's Class</h5>
            </div>
            <div class="card-body">
              <h4><%= todayClass.scheduleInfo.topic %></h4>
              <div class="row">
                <div class="col-md-4">
                  <strong>Faculty</strong>
                  <br />
                  <%= todayClass.facultyUser.name %>
                </div>
                <div class="col-md-4">
                  <strong>Time</strong>
                  <br />
                  <%= todayClass.scheduleInfo.startTime %> - <%= todayClass.scheduleInfo.endTime %>
                </div>
                <div class="col-md-4">
                  <strong>Status</strong>
                  <br />
                  <span class="badge bg-success"> Live Today </span>
                </div>
              </div>
              <hr />
              <a href="<%= todayClass.scheduleInfo.meetingLink %>" class="btn btn-success join-btn">
                <i class="fa-solid fa-video me-2"></i>
                Join Class
              </a>
            </div>
          </div>
        </div>
      </div>
      <%}else{%>
      <!-- Holiday Card -->
     <div class="card card-box holiday mt-4">
        <div class="card-body text-center">
            <h3>
                No classes today!
            </h3>
            <p class="mb-0">
                There are no classes scheduled for today.
                We'll see you
                in the next class.
            </p>
        </div>
      </div> 
      <%}%>

      <!-- Upcoming Classes -->

      <div class="card card-box mt-4">
        <div class="card-header bg-white">
          <h5 class="mb-0">Upcoming Classes</h5>
        </div>

        <div class="card-body">
          <div class="table-responsive">
            <table class="table table-bordered table-hover">
              <thead>
                <tr>
                  <th>Day</th>
                  <th>Topic</th>
                  <th>Faculty</th>
                  <th>Time</th>
                </tr>
              </thead>

              <tbody>
                <%showSchedule.forEach((val)=>{%>
                <tr>
                  <td><%=val.scheduleInfo.day%></td>
                  <td><%=val.scheduleInfo.topic%></td>
                  <td><%=val.facultyUser.name%></td>
                  <td><%=val.scheduleInfo.startTime%> - <%=val.scheduleInfo.endTime%></td>
                </tr>
                <%})%>

              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
        </div>
      </div>
    </div>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
