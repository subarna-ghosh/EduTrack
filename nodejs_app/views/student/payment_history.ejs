<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Payment History</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
    />
    <link rel="stylesheet" href="/assets/css/student_payment_history.css">
  </head>

  <body>
    <div class="container py-5">
      <!-- Heading -->

      <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
          <h2 class="page-title mb-1">Payment History</h2>

          <p class="text-muted mb-0">View all completed payment records</p>
        </div>

        <a href="/web/view/student/pay/now" class="btn btn-primary">
          <i class="fa-solid fa-credit-card me-2"></i>
          Pay Now
        </a>
      </div>

      <!-- Summary Cards -->

      <div class="row g-4 mb-4">
        <div class="col-md-6">
          <div class="summary-card total-paid">
            <h6>Total Amount Paid</h6>

            <h3>₹35,000</h3>
          </div>
        </div>

        <div class="col-md-6">
          <div class="summary-card total-transactions">
            <h6>Total Transactions</h6>

            <h3>3</h3>
          </div>
        </div>
      </div>

      <!-- Payment Table -->

      <div class="card page-card">
        <div class="card-header bg-white py-3">
          <h5 class="mb-0">Completed Transactions</h5>
        </div>

        <div class="card-body">
          <div class="table-responsive">
            <table class="table table-hover align-middle">
              <thead>
                <tr>
                  <th>Transaction ID</th>

                  <th>Amount</th>

                  <th>Method</th>

                  <th>Status</th>

                  <th>Date</th>

                  <th>Action</th>
                </tr>
              </thead>

              <tbody>
                <tr>
                  <td>PAY-1782456987456</td>

                  <td>₹10,000</td>

                  <td>UPI</td>

                  <td>
                    <span class="badge status-paid"> Paid </span>
                  </td>

                  <td>18-Jun-2026</td>

                  <td>
                    <a href="#" class="btn btn-sm btn-outline-primary">
                      View
                    </a>
                  </td>
                </tr>

                <tr>
                  <td>PAY-1782456987660</td>

                  <td>₹10,000</td>

                  <td>Bank Transfer</td>

                  <td>
                    <span class="badge status-paid"> Paid </span>
                  </td>

                  <td>25-Jun-2026</td>

                  <td>
                    <a href="#" class="btn btn-sm btn-outline-primary">
                      View
                    </a>
                  </td>
                </tr>

                <tr>
                  <td>PAY-1782456987777</td>

                  <td>₹15,000</td>

                  <td>Cash</td>

                  <td>
                    <span class="badge status-rejected"> Rejected </span>
                  </td>

                  <td>27-Jun-2026</td>

                  <td>
                    <a href="#" class="btn btn-sm btn-outline-primary">
                      View
                    </a>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
