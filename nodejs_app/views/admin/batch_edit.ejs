<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Update Batch</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <link
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/assets/css/batch.css" />
  </head>

  <body>
    <div class="container py-5">
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <div class="card batch-card">
            <!-- Header -->

            <div class="card-header bg-white py-3">
              <h3 class="page-title mb-0">Update Batch</h3>
            </div>

            <!-- Body -->

            <div class="card-body p-4">
              <form action="/web/update/batch/<%=findBatch[0]._id%>" method="POST">
                <!-- Batch Name -->

                <div class="mb-3">
                  <label class="form-label"> Batch Name </label>

                  <input
                    type="text"
                    name="batchName"
                    class="form-control"
                    placeholder="Example: WA-481"
                    value="<%=findBatch[0].batchName%>"
                    required
                  />
                </div>

                <!-- Course -->

                <div class="mb-3">
                  <label class="form-label"> Select Course </label>           
                  <select name="courseId" class="form-select" required>
                    <option value="">Choose Course</option>
                    <%listCourses.forEach((val)=>{%>               
                    <option value="<%=val._id%>"><%=val.courseName%></option>
                    <%})%>
                  </select>
                </div>

                <!-- Faculty -->

                <div class="mb-3">
                  <label class="form-label"> Select Faculty </label>

                  <select name="facultyId" class="form-select" required>
                    <option value="">Choose Faculty</option>
                    <%findFaculty.forEach((fac)=>{%>
                    <option value="<%=fac._id%>"><%=fac.userInfo.name%></option>
                    <%})%>
                  </select>
                </div>

                <!-- Dates -->

                <div class="row">
                  <div class="col-md-6 mb-3">
                    <label class="form-label"> Start Date </label>

                    <input
                      type="date"
                      name="startDate"
                      class="form-control"
                      required
                    />
                  </div>

                  <div class="col-md-6 mb-3">
                    <label class="form-label"> End Date </label>

                    <input
                      type="date"
                      name="endDate"
                      class="form-control"
                      required
                    />
                  </div>
                </div>

                <!-- Status -->

                <div class="mb-4">
                  <label class="form-label"> Batch Status </label>

                  <select name="status" class="form-select">
                    <option value="active">Active</option>

                    <option value="upcoming">Upcoming</option>

                    <option value="completed">Completed</option>
                  </select>
                </div>

                <!-- Buttons -->

                <div class="d-flex gap-3">
                  <button type="submit" class="btn btn-primary">
                    <i class="fa-solid fa-plus me-2"></i>
                    Update Batch
                  </button>

                  <a href="/web/view/add/batch/list" class="btn btn-secondary">
                    <i class="fa-solid fa-arrow-left me-2"></i>
                    Back
                  </a>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
