<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Student List</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/assets/css/student.css">
  </head>
  <body>
    <div class="page-wrapper">
      <h2 class="page-title">Student List</h2>

      <div class="student-card">
        <div class="top-bar">
          <input
            type="text"
            class="form-control search-box"
            placeholder="Search Student..."
          />

          <div class="d-flex gap-2">
            <a href="/web/view/admin/dashboard" class="btn btn-secondary">
              ← Back to Dashboard
            </a>

            <a href="/web/view/add/student" class="btn btn-primary">
              + Add Student
            </a>
          </div>
        </div>

        <!-- connect-flash -->
        <% if (success.length > 0) { %>
          <div id="successAlert" class="alert alert-info">
             <%= success[0] %>
          </div>
        <% } %>

        <% if (error.length > 0) { %>
          <div id="successAlert" class="alert alert-danger">
             <%= error[0] %>
          </div>
        <% } %>

        <div class="table-responsive">
          <table class="table table-bordered table-hover">
            <thead>
              <tr>
                <th>Sl.no</th>
                <th>Photo</th>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Course</th>
                <th>Batch</th>
                <th>Status</th>
                <th width="180">Action</th>
              </tr>
            </thead>

            <tbody>
              <%findStudent.forEach((student,index)=>{%>
              <tr>
                <td><%=index+1%></td>
                <td>
                  <img
                    src="<%=student.profileImage%>"
                    class="student-image"
                    alt=""
                  />
                </td>
                <td><%=student.userInfo.name%></td>
                <td><%=student.userInfo.email%></td>
                <td><%=student.phone%></td>
                <td><%=student.courseInfo.courseName%></td>
                <td><%=student.batchInfo.batchName%></td>
                <td>
                  <span class="status-active"><%=student.status%></span>
                </td>
                <td>
                  <div class="action-btns">
                    <a href="/web/view/student/profile/<%=student._id %>" class="btn btn-sm btn-info">View</a>
                    <a href="/web/view/edit/student/<%=student._id %>" class="btn btn-sm btn-warning">Edit</a>
                    <a href="/web/delete/student/<%=student._id %>" class="btn btn-sm btn-danger">Delete</a>
                  </div>
                </td>
              </tr>
              <%})%>
            </tbody>
          </table>
        </div>

        <div class="pagination-wrapper">
          <nav>
            <ul class="pagination">
              <li class="page-item">
                <a class="page-link" href="#"> Previous </a>
              </li>

              <li class="page-item active">
                <a class="page-link" href="#"> 1 </a>
              </li>

              <li class="page-item">
                <a class="page-link" href="#"> 2 </a>
              </li>

              <li class="page-item">
                <a class="page-link" href="#"> Next </a>
              </li>
            </ul>
          </nav>
        </div>
      </div>
    </div>
        <script>
      setTimeout(() => {
        const alert = document.getElementById("successAlert");
          if (alert) {
            alert.remove();
          }
        }, 1000); // 1 seconds
    </script>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
