<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Edit Course</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
    />
    <link rel="stylesheet" href="/assets/css/course.css" />
    <link rel="stylesheet" href="/assets/css/sidebar.css">
  </head>

  <body>
    <div class="container py-5">
      <div class="row">
        <!-- SIDEBAR -->
        <%-include('../layouts/admin_sidebar')%>
        <div class="col-lg-8 main-content">
          <div class="card form-card">
            <!-- Header -->

            <div class="card-header bg-white py-3">
              <h3 class="page-title mb-0">Edit Course</h3>
            </div>

            <!-- Body -->

            <div class="card-body p-4">
              <form
                action="/web/save/edit/course/<%=showData._id%>"
                method="POST"
              >
                <!-- Course Name -->

                <div class="mb-3">
                  <label class="form-label"> Course Name </label>

                  <input
                    type="text"
                    name="courseName"
                    class="form-control"
                    placeholder="Enter course name"
                    value="<%=showData.courseName%>"
                    required
                  />
                </div>

                <!-- Duration -->

                <div class="mb-3">
                  <label class="form-label"> Duration </label>

                  <input
                    type="text"
                    name="duration"
                    class="form-control"
                    placeholder="Eg: 6 Months"
                    value="<%=showData.duration%>"
                    required
                  />
                </div>

                <!-- Fees -->

                <div class="mb-3">
                  <label class="form-label"> Course Fees </label>

                  <input
                    type="number"
                    name="fees"
                    class="form-control"
                    placeholder="Enter course fees"
                    value="<%=showData.fees%>"
                    required
                  />
                </div>

                <!-- Description -->

                <div class="mb-3">
                  <label class="form-label"> Description </label>

                  <textarea
                    name="description"
                    rows="5"
                    class="form-control"
                    placeholder="Enter course description"
                    required
                  ><%=showData.description%></textarea>
                </div>

                <!-- Status -->

                <div class="mb-4">
                  <label class="form-label"> Status </label>

                  <select name="status" class="form-select">
                    <option value="active">Active</option>

                    <option value="inactive">Inactive</option>
                  </select>
                </div>

                <!-- Buttons -->

                <div class="d-flex gap-3">
                  <button type="submit" class="btn btn-primary">
                    <i class="fa-solid fa-book me-2"></i>
                    Update Course
                  </button>

                  <a href="/web/view/add/course/list" class="btn btn-secondary">
                    <i class="fa-solid fa-arrow-left me-2"></i>
                    Back
                  </a>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
