<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Create Batch Schedule</title>

    <link 
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
    />
    <link rel="stylesheet" href="/assets/css/admin_schedule_class.css">
    <link rel="stylesheet" href="/assets/css/sidebar.css">
  </head>

  <body>
    <div class="container py-5">
      <div class="row">
        <!-- SIDEBAR -->
        <%-include('../layouts/admin_sidebar')%>
        <div class="col-lg-8 main-content">
          <div class="card schedule-card">
            <div class="card-body p-3">
              <div class="text-center mb-2">
                <h2 class="page-title">Create Batch Schedule</h2>

                <p class="text-muted">
                  Schedule classes for a particular batch.
                </p>
              </div>

              <form action="/web/save/schedule" method="POST">
                <!-- Batch -->

                <div class="mb-3">
                  <label class="form-label"> Batch </label>

                  <select name="batchId" class="form-select" required>
                    <option value="">Select Batch</option> 
                    <%listBatch.forEach((val)=>{%>
                    <option value="<%=val._id%>"><%=val.batchName%>( <%=val.couserInfo.courseName%>)</option>
                    <%})%>
                  </select>
                </div>

                <!-- Faculty -->

                <div class="mb-3">
                  <label class="form-label"> Faculty </label>

                  <select name="facultyId" class="form-select" required>
                    <option value="">Select Faculty</option>
                    <%listFaculty.forEach((data)=>{%>
                    <option value="<%=data._id%>"><%=data.userInfo.name%>( <%=data.batchInfo.batchName%>)</option>
                    <%})%>
                  </select>
                </div>

                <!-- Day -->

                <div class="mb-3">
                  <label class="form-label"> Day </label>
                  <select name="day" class="form-select" required>
                    <option value="">Select Day</option>

                    <option value="Monday">Monday</option>
                    <option value="Tuesday">Tuesday</option>
                    <option value="Wednesday">Wednesday</option>
                    <option value="Thursday">Thursday</option>
                    <option value="Friday">Friday</option>
                    <option value="Saturday">Saturday</option>
                    <option value="Sunday">Sunday</option>
                  </select>
                </div>

                <!-- Time -->

                <div class="row">
                  <div class="col-md-6 mb-3">
                    <label class="form-label"> Start Time </label>
                    <input type="time" name="startTime" class="form-control" required />
                  </div>

                  <div class="col-md-6 mb-3">
                    <label class="form-label"> End Time </label>
                    <input type="time" name="endTime" class="form-control" required />
                  </div>
                </div>

                <!-- Topic -->

                <div class="mb-3">
                  <label class="form-label"> Today's Topic </label>
                  <input
                    type="text"
                    name="topic"
                    class="form-control"
                    placeholder="Example : React Components"
                    required
                  />
                </div>

                <!-- Meeting Link -->

                <div class="mb-3">
                  <label class="form-label"> Google Meet / Zoom Link </label>
                  <input
                    type="url"
                    name="meetingLink"
                    class="form-control"
                    placeholder="http://localhost:3001/web/view/demo...."
                  />
                </div>

                </div>

                <!-- Buttons -->

                <div class="d-flex gap-3">
                  <button type="submit" class="btn btn-primary btn-save">
                    <i class="fa-solid fa-floppy-disk me-2"></i>

                    Save Schedule
                  </button>

                  <a href="/web/view/batch/schedule/list" class="btn btn-secondary btn-save">
                    <i class="fa-solid fa-arrow-left me-2"></i>

                    Back
                  </a>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
