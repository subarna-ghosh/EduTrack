<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create Batch</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <link
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
      rel="stylesheet"
    />

    <style>
      body {
        background: #f5f7fb;
      }

      .batch-card {
        border: none;
        border-radius: 18px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
      }

      .page-title {
        font-weight: 700;
        color: #343a40;
      }

      .form-label {
        font-weight: 600;
      }

      .form-control,
      .form-select {
        height: 50px;
        border-radius: 12px;
      }

      textarea.form-control {
        height: auto;
      }
    </style>
  </head>

  <body>
    <div class="container py-5">
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <div class="card batch-card">
            <!-- Header -->

            <div class="card-header bg-white py-3">
              <h3 class="page-title mb-0">Create Batch</h3>
            </div>

            <!-- Body -->

            <div class="card-body p-4">
              <form action="/batches/create" method="POST">
                <!-- Batch Name -->

                <div class="mb-3">
                  <label class="form-label"> Batch Name </label>

                  <input
                    type="text"
                    name="batchName"
                    class="form-control"
                    placeholder="Example: WA-481"
                    required
                  />
                </div>

                <!-- Course -->

                <div class="mb-3">
                  <label class="form-label"> Select Course </label>

                  <select name="courseId" class="form-select" required>
                    <option value="">Choose Course</option>

                    <option value="1">Node JS Complete</option>

                    <option value="2">React JS</option>

                    <option value="3">MERN Stack</option>
                  </select>
                </div>

                <!-- Faculty -->

                <div class="mb-3">
                  <label class="form-label"> Select Faculty </label>

                  <select name="facultyId" class="form-select" required>
                    <option value="">Choose Faculty</option>

                    <option value="1">Raju Kayal</option>

                    <option value="2">Amit Roy</option>

                    <option value="3">Sayan Das</option>
                  </select>
                </div>

                <!-- Dates -->

                <div class="row">
                  <div class="col-md-6 mb-3">
                    <label class="form-label"> Start Date </label>

                    <input
                      type="date"
                      name="startDate"
                      class="form-control"
                      required
                    />
                  </div>

                  <div class="col-md-6 mb-3">
                    <label class="form-label"> End Date </label>

                    <input
                      type="date"
                      name="endDate"
                      class="form-control"
                      required
                    />
                  </div>
                </div>

                <!-- Status -->

                <div class="mb-4">
                  <label class="form-label"> Batch Status </label>

                  <select name="status" class="form-select">
                    <option value="active">Active</option>

                    <option value="upcoming">Upcoming</option>

                    <option value="completed">Completed</option>
                  </select>
                </div>

                <!-- Buttons -->

                <div class="d-flex gap-3">
                  <button type="submit" class="btn btn-primary">
                    <i class="fa-solid fa-plus me-2"></i>
                    Create Batch
                  </button>

                  <a href="/web/view/add/batch/list" class="btn btn-secondary">
                    <i class="fa-solid fa-arrow-left me-2"></i>
                    Back
                  </a>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
