<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
      crossorigin="anonymous"
    />
  </head>
  <body>
    <!doctype html>
    <html lang="en">
      <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />

        <title>LMS Admin Dashboard</title>

        <link
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet"
        />
        <link
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
          rel="stylesheet"
        />
        <link rel="stylesheet" href="/assets/css/admin_style.css"></link>
      </head>

      <body>
        <div class="container-fluid">
          <div class="row">
            <!-- SIDEBAR -->

            <div class="col-lg-2 sidebar">
              <div class="logo">EduTrack</div>

              <ul class="nav flex-column">
                <li>
                  <a href="#" class="nav-link active"
                    ><i class="fa-solid fa-chart-line"></i> Dashboard</a
                  >
                </li>

                <li>
                  <a href="/web/view/add/student/list" class="nav-link"
                    ><i class="fa-solid fa-user-graduate"></i> Students</a
                  >
                </li>

                <li>
                  <a href="/web/view/add/faculty/list" class="nav-link"
                    ><i class="fa-solid fa-chalkboard-user"></i> Faculties</a
                  >
                </li>

                <li>
                  <a href="/web/view/add/course/list" class="nav-link"
                    ><i class="fa-solid fa-book"></i> Courses</a
                  >
                </li>

                <li>
                  <a href="/web/view/add/batch/list" class="nav-link"
                    ><i class="fa-solid fa-users"></i> Batches</a
                  >
                </li>

                <li>
                  <a href="/web/view/attendance/list" class="nav-link"
                    ><i class="fa-solid fa-calendar-check"></i> Attendance</a
                  >
                </li>

                <li>
                  <a href="/web/view/payment/management" class="nav-link"
                    ><i class="fa-solid fa-money-bill"></i> Payments</a
                  >
                </li>

                <li>
                  <a href="#" class="nav-link"
                    ><i class="fa-solid fa-chart-pie"></i> Reports</a
                  >
                </li>

                <li>
                  <a href="/web/logout" class="nav-link">
                    <i class="fa-solid fa-right-from-bracket"></i> Logout</a
                  >
                </li>
              </ul>
            </div>

            <!-- MAIN CONTENT -->

            <div class="col-lg-10 main-content">
              <!-- TOPBAR -->

              <!-- navbar -->
              <nav class="topbar">
                <div>
                  <h2 class="page-title">Dashboard</h2>
                  <p class="page-subtitle">Welcome back, Admin</p>
                </div>

                <div class="top-right">
                  <!-- Notifications -->
                  <button class="top-btn notification-btn">
                    <i class="fa-regular fa-bell"></i>
                    <span class="notification-count">5</span>
                  </button>

                  <!-- Announcements -->
                  <a href="/web/view/announcement/list" class="top-btn">
                    <i class="fa-solid fa-bullhorn"></i>
                    Announcements
                  </a>

                  <!-- Quick Add -->
                  <div class="dropdown">
                    <button
                      class="quick-add-btn dropdown-toggle"
                      data-bs-toggle="dropdown"
                    >
                      <i class="fa-solid fa-plus"></i>
                      Quick Add
                    </button>

                    <ul class="dropdown-menu dropdown-menu-end">
                      <li>
                        <a class="dropdown-item" href="/web/view/add/student"> Add Student </a>
                      </li>

                      <li>
                        <a class="dropdown-item" href="/web/view/add/faculty"> Add Faculty </a>
                      </li>

                      <li>
                        <a class="dropdown-item" href="/web/view/add/course"> Add Course </a>
                      </li>

                      <li>
                        <a class="dropdown-item" href="/web/view/add/batch"> Add Batch </a>
                      </li>
                    </ul>
                  </div>

                  <!-- Admin Profile -->
                  <div class="dropdown">
                    <button
                      class="profile-dropdown dropdown-toggle"
                      data-bs-toggle="dropdown"
                    >
                      <i class="fa-solid fa-user-shield me-2"></i>
                      Admin
                    </button>

                    <ul class="dropdown-menu dropdown-menu-end">
                      <li>
                        <a class="dropdown-item" href="#"> Profile </a>
                      </li>

                      <li>
                        <a class="dropdown-item" href="#"> Settings </a>
                      </li>

                      <li><hr class="dropdown-divider" /></li>

                      <li>
                        <a class="dropdown-item text-danger" href="/web/logout">
                          Logout
                        </a>
                      </li>
                    </ul>
                  </div>
                </div>
              </nav>

              <!-- HEADING -->
                             <div class="page-heading">
                <div>
                  <h2>Dashboard</h2>
                  <p>Monitor students, faculties, batches and revenue.</p>
                </div>
                <a href="/web/view/add/student" class="btn btn-primary">Add Student</a>
              </div>

              <% if(success && success.length > 0){ %>
                <div id="successAlert" class="alert alert-success alert-dismissible fade show">
                  <%= success[0] %>
                </div>
              <% } %>

              <!-- STATS -->

              <div class="row g-4 mb-4">
                <div class="col-lg-3">
                  <div class="stats-card border-blue">
                    <h6>Total Students</h6>
                    <h2><%=totalStudent%></h2>
                  </div>
                </div>

                <div class="col-lg-3">
                  <div class="stats-card border-green">
                    <h6>Total Faculties</h6>
                    <h2><%=totalFaculty%></h2>
                  </div>
                </div>

                <div class="col-lg-3">
                  <div class="stats-card border-orange">
                    <h6>Total Courses</h6>
                    <h2><%=totalCourse%></h2>
                  </div>
                </div>

                <div class="col-lg-3">
                  <div class="stats-card border-red">
                    <h6>Active Batches</h6>
                    <h2><%=totalActiveBatch%></h2>
                  </div>
                </div>
              </div>
              <!-- REVENUE STATS -->

              <div class="row g-4 mb-4">
                <div class="col-lg-4">
                  <div class="stats-card">
                    <h6>Total Revenue</h6>
                    <h2>₹24,50,000</h2>
                  </div>
                </div>

                <div class="col-lg-4">
                  <div class="stats-card">
                    <h6>Pending Payments</h6>
                    <h2>28</h2>
                  </div>
                </div>

                <div class="col-lg-4">
                  <div class="stats-card">
                    <h6>Pending Documents</h6>
                    <h2>17</h2>
                  </div>
                </div>
              </div>

              <!-- CHART + ACTIVITY -->

              <div class="row g-4 mb-4">
                <div class="col-lg-8">
                  <div class="dashboard-card">
                    <div class="card-header-custom">
                      <h5>Revenue Performance</h5>
                    </div>

                    <canvas id="revenueChart"></canvas>
                  </div>
                </div>

                <div class="col-lg-4">
                  <div class="dashboard-card">
                    <h5 class="mb-4">Recent Activities</h5>

                    <div class="activity-item">
                      Student enrolled in MERN Stack
                    </div>

                    <div class="activity-item">Payment received from Rahul</div>

                    <div class="activity-item">New Batch WA-510 created</div>

                    <div class="activity-item">React course published</div>
                  </div>
                </div>
              </div>

              <!-- TODAY'S CLASSES -->

              <div class="dashboard-card mb-4">
                <h5 class="mb-3">Today's Classes</h5>

                <table class="table">
                  <thead>
                    <tr>
                      <th>Course</th>
                      <th>Faculty</th>
                      <th>Batch</th>
                      <th>Time</th>
                    </tr>
                  </thead>

                  <tbody>
                    <tr>
                      <td>Node JS</td>
                      <td>Raju Kayal</td>
                      <td>WA-481</td>
                      <td>10:00 AM</td>
                    </tr>

                    <tr>
                      <td>React JS</td>
                      <td>Amit Roy</td>
                      <td>WA-500</td>
                      <td>02:00 PM</td>
                    </tr>
                  </tbody>
                </table>
              </div>

              <!-- RECENT + QUICK ACTION -->

              <div class="row g-4">
                <div class="col-lg-8">
                  <div class="dashboard-card">
                    <h5 class="mb-3">Recent Enrollments</h5>

                    <table class="table">
                      <thead>
                        <tr>
                          <th>Name</th>
                          <th>Course</th>
                        </tr>
                      </thead>

                      <tbody>
                        <tr>
                          <td>Subarna Ghosh</td>
                          <td>Node JS Complete</td>
                        </tr>

                        <tr>
                          <td>Rahul Das</td>
                          <td>React JS</td>
                        </tr>
                      </tbody>
                    </table>
                  </div>
                </div>

                <div class="col-lg-4">
                  <div class="dashboard-card">
                    <h5 class="mb-4">Quick Actions</h5>

                    <div class="d-grid gap-3">
                      <a href="/web/view/add/student" class="btn btn-primary">
                        Add Student
                      </a>

                      <a href="/web/view/add/batch" class="btn btn-success">
                        Create Batch
                      </a>

                      <a href="/web/view/add/faculty" class="btn btn-warning">
                        Add Faculty
                      </a>

                      <a
                        href="/web/view/announcement/list"
                        class="btn btn-danger"
                      >
                        Upload Announcement
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

        <script>
          setTimeout(() => {
            const alert = document.getElementById("successAlert");
            if (alert) {
              alert.remove();
            }
          }, 3000); // 3 seconds

          const ctx = document.getElementById("revenueChart");

          new Chart(ctx, {
            type: "bar",
            data: {
              labels: ["Jan", "Feb", "Mar", "Apr", "May", "Jun"],
              datasets: [
                {
                  label: "Revenue",
                  data: [120000, 180000, 150000, 220000, 210000, 260000],
                },
              ],
            },
          });
        </script>
      </body>
    </html>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
