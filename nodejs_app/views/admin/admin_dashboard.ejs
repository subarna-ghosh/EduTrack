 <!doctype html>
    <html lang="en">
      <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />

        <title>LMS Admin Dashboard</title>

        <link
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet"
        />
        <link
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
          rel="stylesheet"
        />
        <link rel="stylesheet" href="/assets/css/admin_style.css"></link>
        <link rel="stylesheet" href="/assets/css/sidebar.css"></link>
        <link rel="stylesheet" href="/assets/css/admin_navbar.css"></link>
      </head>

      <body>
        <div class="container-fluid">
          <div class="row">
            <!-- SIDEBAR -->
             <%-include('../layouts/admin_sidebar')%>

            <!-- MAIN CONTENT -->

            <div class="col-lg-10 main-content">
              <!-- TOPBAR -->

              <!-- navbar -->
              <%-include('../layouts/admin_navbar')%>            
              <!-- HEADING -->
              <div class="page-heading">
                <div>
                  <h2>Dashboard</h2>
                  <p>Monitor students, faculties, batches and revenue.</p>
                </div>
                <a href="/web/view/add/student" class="btn btn-primary">Add Student</a>
              </div>

              <% if(success && success.length > 0){ %>
                <div id="successAlert" class="alert alert-success alert-dismissible fade show">
                  <%= success[0] %>
                </div>
              <% } %>

              <!-- STATS -->

              <div class="row g-4 mb-4">
                <div class="col-lg-3">
                  <div class="stats-card border-blue">
                    <h6>Total Students</h6>
                    <h2><%=totalStudent%></h2>
                  </div>
                </div>

                <div class="col-lg-3">
                  <div class="stats-card border-green">
                    <h6>Total Faculties</h6>
                    <h2><%=totalFaculty%></h2>
                  </div>
                </div>

                <div class="col-lg-3">
                  <div class="stats-card border-orange">
                    <h6>Total Courses</h6>
                    <h2><%=totalCourse%></h2>
                  </div>
                </div>

                <div class="col-lg-3">
                  <div class="stats-card border-red">
                    <h6>Active Batches</h6>
                    <h2><%=totalActiveBatch%></h2>
                  </div>
                </div>
              </div>
              <!-- REVENUE STATS -->

              <div class="row g-4 mb-4">
                <div class="col-lg-4">
                  <div class="stats-card">
                    <h6>Total Revenue</h6>
                    <h2>₹<%= totalRevenue.length > 0 ? totalRevenue[0].totalRev : 0 %></h2>
                  </div>
                </div>

                <div class="col-lg-4">
                  <div class="stats-card">
                    <h6>Pending Payments</h6>
                    <h2><%=pendingPayments%></h2>
                  </div>
                </div>

                <div class="col-lg-4">
                  <div class="stats-card">
                    <h6>Pending Documents</h6>
                    <h2>17</h2>
                  </div>
                </div>
              </div>

              <!-- CHART + ACTIVITY -->

              <div class="row g-4 mb-4">
                <div class="col-lg-8">
                  <div class="dashboard-card">
                    <div class="card-header-custom">
                      <h5>Fee Collection Overview</h5>
                    </div>

                    <canvas id="feeChart"></canvas>
                  </div>
                </div>

                <div class="col-lg-4">
                  <div class="dashboard-card">
                    <h5 class="mb-4">Recent Activities</h5>

                    <div class="activity-item">
                      Student enrolled in MERN Stack
                    </div>

                    <div class="activity-item">Payment received from Rahul</div>

                    <div class="activity-item">New Batch WA-510 created</div>

                    <div class="activity-item">React course published</div>
                  </div>
                </div>
              </div>

              <!-- TODAY'S CLASSES -->

              <div class="dashboard-card mb-4">

                <!-- Card Header -->
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h5 class="mb-1 fw-bold">
                            <i class="fa-solid fa-calendar-day text-primary me-2"></i>
                            Today's Classes
                        </h5>
                        <small class="text-muted">Scheduled classes for today</small>
                    </div>

                    <a href="/web/view/batch/schedule/list" class="btn btn-outline-primary btn-sm">
                       View All
                    </a>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">

                        <thead class="table-light">
                            <tr>
                                <th>Course</th>
                                <th>Faculty</th>
                                <th>Batch</th>
                                <th>Time</th>
                                <th>Status</th>
                            </tr>
                        </thead>

                        <tbody>
                          <%listBatch.forEach((val)=>{%>
                            <tr>
                                <td>
                                    <div class="fw-semibold"><%=val.courseInfo.courseName%></div>
                                    <small class="text-muted"><%=val.topic%></small>
                                </td>
                                <td>
                                    <i class="fa-solid fa-user-tie text-secondary me-2"></i>
                                    <%=val.userInfo.name%>
                                </td>
                                <td>
                                    <span class="badge bg-primary-subtle text-primary px-3 py-2">
                                    <%=val.batchInfo.batchName%>
                                    </span>
                                </td>
                                <td>
                                    <i class="fa-regular fa-clock text-success me-2"></i>
                                    <%=val.startTime%> - <%=val.endTime%>
                                </td>
                                <td>
                                  <% if (val.status === "Upcoming") { %>
                                    <span class="badge bg-primary">Upcoming</span>
                                  <% } else if (val.status === "Ongoing") { %>
                                    <span class="badge bg-success">Ongoing</span>
                                  <% } else { %>
                                    <span class="badge bg-secondary">Completed</span>
                                  <% } %>
                                </td>
                            </tr>
                          <%})%>
                      </tbody>
                    </table>
                </div>
            </div>

              <!-- RECENT + QUICK ACTION -->

              <div class="row g-4">
                <div class="col-lg-8">
                  <div class="dashboard-card">
                    <h5 class="mb-3">Recent Enrollments</h5>

                    <table class="table">
                      <thead>
                        <tr>
                          <th>Name</th>
                          <th>Course</th>
                        </tr>
                      </thead>

                      <tbody>
                        <tr>
                          <td>Subarna Ghosh</td>
                          <td>Node JS Complete</td>
                        </tr>

                        <tr>
                          <td>Rahul Das</td>
                          <td>React JS</td>
                        </tr>
                      </tbody>
                    </table>
                  </div>
                </div>

                <div class="col-lg-4">
                  <div class="dashboard-card">
                    <h5 class="mb-4">Quick Actions</h5>

                    <div class="d-grid gap-3">
                      <a href="/web/view/add/student" class="btn btn-primary">
                        Add Student
                      </a>

                      <a href="/web/view/add/batch" class="btn btn-success">
                        Create Batch
                      </a>

                      <a href="/web/view/add/faculty" class="btn btn-warning">
                        Add Faculty
                      </a>

                      <a
                        href="/web/view/announcement/list"
                        class="btn btn-danger"
                      >
                        Upload Announcement
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        
<!-- Load Chart.js FIRST -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
      crossorigin="anonymous">
    </script>

    <!-- Then your script that uses Chart -->
    <script>
      setTimeout(() => {
        const alert = document.getElementById("successAlert");
        if (alert) alert.remove();
      }, 3000);

      const ctx = document.getElementById("feeChart");
      new Chart(ctx, {
        type: "bar",
        data: {
          labels: ["Assigned Fee", "Collected Fee", "Due Fee"],
          datasets: [{
            label: "Amount (₹)",
            data: ["<%= assignedFee %>", "<%= collected %>"," <%= dueAmount %>"],
            backgroundColor: ["rgba(54, 162, 235, 0.2)","rgba(75, 192, 192, 0.2)", "rgba(255, 99, 132, 0.2)"],
            borderColor: ["rgb(54, 162, 235)","rgb(75, 192, 192)","rgb(255, 99, 132)"],
            borderWidth: 1
          }],
        },
        options: {
          responsive: true,
          scales: { y: { beginAtZero: true }}
        }
      });
    </script>
  </body>
</html>
