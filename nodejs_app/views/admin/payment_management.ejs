<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Payment Management</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
    />
    <link rel="stylesheet" href="/assets/css/admin_payment.css" />
  </head>

  <body>
    <div class="container-fluid py-4">
      <!-- Header -->

      <div class="page-header">
        <div
          class="d-flex justify-content-between align-items-center flex-wrap gap-3"
        >
          <div>
            <h2 class="mb-1">Payment Management</h2>

            <p class="mb-0">Manage student fees, dues and payment records</p>
          </div>

          <div class="d-flex gap-2">
            <a href="/web/view/admin/dashboard" class="btn btn-light btn-back">
              <i class="fa-solid fa-arrow-left me-2"></i>
              Back
            </a>

            <a href="/web/view/assign/fee" class="btn btn-success">
              <i class="fa-solid fa-money-bill-wave me-2"></i>
              Assign Fee
            </a>

            <button class="btn btn-warning text-dark">
              <i class="fa-solid fa-download me-2"></i>
              Export
            </button>
          </div>
        </div>
      </div>

      <!-- Statistics -->

      <div class="row g-4 mb-4">
        <div class="col-lg-3 col-md-6">
          <div class="card stat-card card-blue">
            <div class="card-body">
              <div class="d-flex justify-content-between">
                <div>
                  <small>Total Assigned Fee</small>

                  <div class="stat-value">₹18.5L</div>
                </div>

                <div class="stat-icon bg-primary text-white">
                  <i class="fa-solid fa-wallet"></i>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="col-lg-3 col-md-6">
          <div class="card stat-card card-green">
            <div class="card-body">
              <div class="d-flex justify-content-between">
                <div>
                  <small>Total Collected</small>

                  <div class="stat-value">₹12.5L</div>
                </div>

                <div class="stat-icon bg-success text-white">
                  <i class="fa-solid fa-circle-check"></i>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="col-lg-3 col-md-6">
          <div class="card stat-card card-red">
            <div class="card-body">
              <div class="d-flex justify-content-between">
                <div>
                  <small>Total Due</small>

                  <div class="stat-value text-danger">₹6L</div>
                </div>

                <div class="stat-icon bg-danger text-white">
                  <i class="fa-solid fa-triangle-exclamation"></i>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="col-lg-3 col-md-6">
          <div class="card stat-card card-orange">
            <div class="card-body">
              <div class="d-flex justify-content-between">
                <div>
                  <small>Pending Requests</small>

                  <div class="stat-value">28</div>
                </div>

                <div class="stat-icon bg-warning text-dark">
                  <i class="fa-solid fa-clock"></i>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Filters -->

      <div class="card filter-card mb-4">
        <div class="card-body">
          <div class="row g-3">
            <div class="col-lg-4">
              <input
                type="text"
                class="form-control"
                placeholder="Search student name..."
              />
            </div>

            <div class="col-lg-3">
              <select class="form-select">
                <option>All Status</option>
                <option>Paid</option>
                <option>Pending</option>
                <option>Failed</option>
              </select>
            </div>

            <div class="col-lg-3">
              <select class="form-select">
                <option>All Methods</option>
                <option>UPI</option>
                <option>Cash</option>
                <option>Card</option>
                <option>Bank</option>
              </select>
            </div>

            <div class="col-lg-2">
              <button class="btn btn-primary w-100">Filter</button>
            </div>
          </div>
        </div>
      </div>

      <!-- Pending Payment Requests -->

      <div class="card table-card">
        <div class="card-header bg-white py-3">
          <h5 class="mb-0">Pending Payment Requests</h5>
        </div>

        <div class="card-body">
          <div class="table-responsive">
            <table class="table table-hover align-middle">
              <thead>
                <tr>
                  <th>Student</th>
                  <th>Amount</th>
                  <th>Payment Method</th>
                  <th>Transaction ID</th>
                  <th>Requested On</th>
                  <th>Status</th>
                  <th>Action</th>
                </tr>
              </thead>

              <tbody>

                <tr>
                  <td>Subarna Ghosh</td>

                  <td>₹10,000</td>

                  <td>
                    <span class="badge bg-light text-dark border"> UPI </span>
                  </td>

                  <td>PAY-1782456987456</td>

                  <td>18-Jun-2026</td>

                  <td>
                    <span class="badge bg-warning text-dark"> Pending </span>
                  </td>

                  <td>
                    <button
                      class="btn btn-primary btn-sm"
                      data-bs-toggle="modal"
                      data-bs-target="#paymentModal"
                    >
                      View
                    </button>
                  </td>
                </tr>
                
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <!-- modal -->
    <div class="modal fade" id="paymentModal" tabindex="-1">
      <div class="modal-dialog modal-lg">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">Payment Details</h5>

            <button
              type="button"
              class="btn-close"
              data-bs-dismiss="modal"
            ></button>
          </div>

          <div class="modal-body">
            <div class="row">
              <div class="col-md-6">
                <h6 class="mb-3">Student Information</h6>

                <p><strong>Name:</strong> Subarna Ghosh</p>

                <p><strong>Student Code:</strong> STU001</p>

                <p><strong>Batch:</strong> WA-481</p>

                <p><strong>Course:</strong> Node JS Complete</p>
              </div>

              <div class="col-md-6">
                <h6 class="mb-3">Payment Information</h6>

                <p><strong>Amount:</strong> ₹10,000</p>

                <p><strong>Method:</strong> UPI</p>

                <p>
                  <strong>Transaction ID:</strong>
                  PAY-1782456987456
                </p>

                <p>
                  <strong>Status:</strong>

                  <span class="badge bg-warning text-dark"> Pending </span>
                </p>
              </div>
            </div>

            <hr />

            <h6 class="mb-3">Fee Summary</h6>

            <div class="row">
              <div class="col-md-4">
                <div class="alert alert-primary mb-0">
                  Total Fee <br />
                  <strong>₹50,000</strong>
                </div>
              </div>

              <div class="col-md-4">
                <div class="alert alert-success mb-0">
                  Paid <br />
                  <strong>₹35,000</strong>
                </div>
              </div>

              <div class="col-md-4">
                <div class="alert alert-danger mb-0">
                  Due <br />
                  <strong>₹15,000</strong>
                </div>
              </div>
            </div>
          </div>

          <div class="modal-footer">
            <form action="#" method="POST">
              <button type="submit" class="btn btn-success">Approve</button>
            </form>

            <form action="#" method="POST">
              <button type="submit" class="btn btn-danger">Reject</button>
            </form>
          </div>
        </div>
      </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
