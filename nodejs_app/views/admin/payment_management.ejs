<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Payment Management</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
    />
    <link rel="stylesheet" href="/assets/css/admin_payment.css" />
  </head>

  <body>
    <div class="container-fluid py-4">
      <!-- Header -->

      <div class="page-header">
        <div
          class="d-flex justify-content-between align-items-center flex-wrap gap-3"
        >
          <div>
            <h2 class="mb-1">Payment Management</h2>

            <p class="mb-0">Manage student fees, dues and payment records</p>
          </div>
          <div class="d-flex gap-2">
            <!-- Back -->
            <a href="/web/view/admin/dashboard" class="btn btn-light btn-back">
              <i class="fa-solid fa-arrow-left me-2"></i>
              Back
            </a>

            <!-- Payment Dropdown -->
            <div class="dropdown">
              <button
                class="btn btn-success dropdown-toggle"
                type="button"
                data-bs-toggle="dropdown"
                aria-expanded="false"
              >
                <i class="fa-solid fa-wallet me-2"></i>
                Payment Records
              </button>

              <ul class="dropdown-menu dropdown-menu-end shadow">
                <li>
                  <a class="dropdown-item" href="/web/view/assign/fee">
                    <i
                      class="fa-solid fa-money-bill-wave me-2 text-success"
                    ></i>
                    Assign Fee
                  </a>
                </li>

                <li>
                  <a
                    class="dropdown-item"
                    href="/web/view/assigned/fee/student"
                  >
                    <i class="fa-solid fa-users me-2 text-primary"></i>
                    Assigned Fees
                  </a>
                </li>

                <li>
                  <a class="dropdown-item" href="/web/view/payment/record">
                    <i
                      class="fa-solid fa-file-invoice-dollar me-2 text-info"
                    ></i>
                    Payment History
                  </a>
                </li>
              </ul>
            </div>

            <!-- Export -->
            <button class="btn btn-warning text-dark">
              <i class="fa-solid fa-download me-2"></i>
              Export
            </button>
          </div>
        </div>
      </div>

      <!-- Statistics -->

      <div class="row g-4 mb-4">
        <div class="col-lg-3 col-md-6">
          <div class="card stat-card">
            <div class="card-body">
              <div class="d-flex justify-content-between">
                <div>
                  <small>Total Assigned Fee</small>
                  <div class="stat-value">
                    ₹<%=totalAssignedFee[0].totalFee%>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="col-lg-3 col-md-6">
          <div class="card stat-card">
            <div class="card-body">
              <div class="d-flex justify-content-between">
                <div>
                  <small>Total Collected</small>
                  <div class="stat-value">
                    ₹<%=totalCollected[0].totalCollect%>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="col-lg-3 col-md-6">
          <div class="card stat-card">
            <div class="card-body">
              <div class="d-flex justify-content-between">
                <div>
                  <small>Total Due</small>
                  <div class="stat-value text-danger">
                    ₹<%=totalDueAmount[0].totalDue%>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="col-lg-3 col-md-6">
          <div class="card stat-card">
            <div class="card-body">
              <div class="d-flex justify-content-between">
                <div>
                  <small>Pending Requests</small>
                  <div class="stat-value"><%=totalPendingRequest%></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Payment Method Distribution -->
      <div class="card table-card mb-4">
        <div
          class="card-header bg-white py-3 d-flex justify-content-between align-items-center"
        >
          <h5 class="mb-0">
            <i class="fa-solid fa-chart-pie text-primary me-2"></i>
            Payment Method Distribution
          </h5>
          <small class="text-muted"> Based on all payment requests </small>
        </div>

        <div class="card-body">
          <div class="row align-items-center">
            <!-- Pie Chart -->
            <div class="col-lg-6">
              <canvas
                id="paymentMethodChart"
                style="max-width: 260px; max-height: 260px; margin: auto"
              ></canvas>
            </div>

            <!-- Summary -->
            <div class="col-lg-6"> 
              <div
                class="d-flex justify-content-between align-items-center mb-3"
              >
                <span>
                  <i class="fa-solid fa-circle me-2" style="color:#ff6384;"></i>
                  UPI Payments
                </span>
                <strong><%=upiCount%></strong>
              </div>

              <div
                class="d-flex justify-content-between align-items-center mb-3"
              >
                <span>
                  <i class="fa-solid fa-circle me-2" style="color:#ff9f63;"></i>
                  Cash Payments
                </span>
                <strong><%=cashCount%></strong>
              </div>

              <div
                class="d-flex justify-content-between align-items-center mb-3"
              >
                <span>
                  <i class="fa-solid fa-circle me-2" style="color:#ffe563;"></i>
                  Card Payments
                </span>
                <strong><%=cardCount%></strong>
              </div>

              <div class="d-flex justify-content-between align-items-center">
                <span>
                  <i class="fa-solid fa-circle me-2" style="color:#5accc1;"></i>
                  Bank Transfers
                </span>
                <strong><%=bankCount%></strong>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Pending Payment Requests -->
       <div class="card table-card">
        <div class="card-header bg-white py-3">
          <h5 class="mb-0 head-style">Pending Payment Requests</h5>
        </div>

        <div class="card-body">
          <div class="table-responsive">
            <table class="table table-hover align-middle">
              <thead>
                <tr>
                  <th>Student</th>
                  <th>Amount</th>
                  <th>Payment Method</th>
                  <th>Transaction ID</th>
                  <th>Requested On</th>
                  <th>Status</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <%if(findPayment.length===0){%>
                  <tr>
                    <td colspan="7" style="text-align: center;">No pending payments!</td>
                  </tr>
                <%}else{%>
                <%findPayment.forEach((data)=>{%>
                <tr>
                  <td><%=data.userInfo.name%></td>
                  <td>₹<%=data.amount%></td>
                  <td>
                    <span class="badge bg-light text-dark border"><%=data.paymentMethod%></span>
                  </td>
                  <td><%=data.transactionId%></td>
                  <td><%=new Date(data.createdAt).toLocaleDateString("en-GB")%></td>
                  <td>
                    <span class="badge bg-warning text-dark"><%=data.paymentStatus%></span>
                  </td>
                  <td>
                    <button
                      class="btn btn-primary btn-sm view-btn"
                      data-bs-toggle="modal"
                      data-bs-target="#paymentModal"
                      data-name="<%=data.userInfo ? data.userInfo.name : 'N/A'%>"
                      data-amount="<%=data.amount%>"
                      data-method="<%=data.paymentMethod%>"
                      data-txn="<%=data.transactionId%>"
                      data-status="<%=data.paymentStatus%>"
                      data-id="<%=data._id%>"
                    >
                      View
                    </button>
                  </td>
                </tr>
                <%})%>
                <%}%>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
    <!-- modal -->
    <div class="modal fade" id="paymentModal" tabindex="-1">
      <div class="modal-dialog modal-lg">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">Payment Details</h5>
            <button
              type="button"
              class="btn-close"
              data-bs-dismiss="modal"
            ></button>
          </div>

          <div class="modal-body">
            <p>
              <strong>Student :</strong>
              <span id="modal-name"></span>
            </p>

            <p>
              <strong>Amount :</strong>
              ₹<span id="modal-amount"></span>
            </p>

            <p>
              <strong>Payment Method :</strong>
              <span id="modal-method"></span>
            </p>

            <p>
              <strong>Transaction ID :</strong>
              <span id="modal-txn"></span>
            </p>

            <p>
              <strong>Status :</strong>

              <span id="modal-status" class="badge bg-warning text-dark">
              </span>
            </p>
          </div>

          <div class="modal-footer">
            <form id="approve-form" method="POST">
              <button class="btn btn-success">Approve</button>
            </form>

            <form id="reject-form" method="POST">
              <button class="btn btn-danger">Reject</button>
            </form>
          </div>
        </div>
      </div>
    </div>
    <script>
      const viewButtons = document.querySelectorAll(".view-btn");

      viewButtons.forEach((btn) => {
        btn.addEventListener("click", () => {
          document.getElementById("modal-name").textContent = btn.dataset.name;

          document.getElementById("modal-amount").textContent =
            btn.dataset.amount;

          document.getElementById("modal-method").textContent =
            btn.dataset.method;

          document.getElementById("modal-txn").textContent = btn.dataset.txn;

          document.getElementById("modal-status").textContent =
            btn.dataset.status;

          document.getElementById("approve-form").action =
            "/web/admin/payment/approve/" + btn.dataset.id;

          document.getElementById("reject-form").action =
            "/web/admin/payment/reject/" + btn.dataset.id;
        });
      });
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
      const ctx = document.getElementById("paymentMethodChart");

      new Chart(ctx, {
        type: "pie",

        data: {
          labels: ["UPI", "Cash", "Card", "Bank"],

          datasets: [
            {
              data: [
                "<%=upiCount%>",
                "<%=cashCount%>",
                "<%=cardCount%>",
                "<%=bankCount%>",
              ],

              backgroundColor: [
                "rgba(255, 99, 132, 0.2)",
                "rgba(255, 159, 64, 0.2)",
                "rgba(255, 205, 86, 0.2)",
                "rgba(75, 192, 192, 0.2)",
              ],
              borderColor: [
                "rgb(255, 99, 132)",
                "rgb(255, 159, 64)",
                "rgb(255, 205, 86)",
                "rgb(75, 192, 192)",
              ],
              borderWidth: 2,
            },
          ],
        },

        options: {
          responsive: true,

          plugins: {
            legend: {
              position: "bottom",
            },
          },
        },
      });
    </script>
  </body>
</html>
