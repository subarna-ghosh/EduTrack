<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Admin Payment Management</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
    />

    <style>
      body {
        background: #f4f6f9;
      }

      .page-title {
        font-weight: 700;
      }

      .stats-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 0.15rem 1.75rem rgba(58, 59, 69, 0.15);
      }

      .stats-card .card-body {
        padding: 25px;
      }

      .stats-number {
        font-size: 28px;
        font-weight: 700;
      }

      .filter-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 0.15rem 1.75rem rgba(58, 59, 69, 0.15);
      }

      .table-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 0.15rem 1.75rem rgba(58, 59, 69, 0.15);
      }

      .badge-paid {
        background: #198754;
      }

      .badge-pending {
        background: #ffc107;
        color: #000;
      }

      .badge-failed {
        background: #dc3545;
      }

      .table th {
        white-space: nowrap;
      }
    </style>
  </head>

  <body>
    <div class="container-fluid py-4">
      <!-- Header -->

      <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
          <h2 class="page-title mb-1">Payment Management</h2>

          <p class="text-muted mb-0">
            Manage all student payments and transactions
          </p>
        </div>

        <button class="btn btn-primary">
          <i class="fa-solid fa-download me-2"></i>

          Export Payments
        </button>
      </div>

      <!-- Statistics -->

      <div class="row g-4 mb-4">
        <div class="col-lg-3">
          <div class="card stats-card">
            <div class="card-body">
              <small class="text-muted"> Total Revenue </small>

              <div class="stats-number mt-2">₹12,50,000</div>
            </div>
          </div>
        </div>

        <div class="col-lg-3">
          <div class="card stats-card">
            <div class="card-body">
              <small class="text-muted"> Paid Payments </small>

              <div class="stats-number mt-2">420</div>
            </div>
          </div>
        </div>

        <div class="col-lg-3">
          <div class="card stats-card">
            <div class="card-body">
              <small class="text-muted"> Pending Payments </small>

              <div class="stats-number mt-2">38</div>
            </div>
          </div>
        </div>

        <div class="col-lg-3">
          <div class="card stats-card">
            <div class="card-body">
              <small class="text-muted"> Failed Payments </small>

              <div class="stats-number mt-2">7</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Filters -->

      <div class="card filter-card mb-4">
        <div class="card-body">
          <div class="row g-3">
            <div class="col-lg-4">
              <input
                type="text"
                class="form-control"
                placeholder="Search student..."
              />
            </div>

            <div class="col-lg-3">
              <select class="form-select">
                <option>All Status</option>

                <option>Paid</option>

                <option>Pending</option>

                <option>Failed</option>
              </select>
            </div>

            <div class="col-lg-3">
              <select class="form-select">
                <option>All Methods</option>

                <option>UPI</option>

                <option>Cash</option>

                <option>Card</option>

                <option>Bank</option>
              </select>
            </div>

            <div class="col-lg-2">
              <button class="btn btn-primary w-100">Filter</button>
            </div>
          </div>
        </div>
      </div>

      <!-- Payment Table -->

      <div class="card table-card">
        <div class="card-header bg-white">
          <h5 class="mb-0">Payment List</h5>
        </div>

        <div class="card-body">
          <div class="table-responsive">
            <table class="table table-hover align-middle">
              <thead>
                <tr>
                  <th>Student</th>

                  <th>Amount</th>

                  <th>Method</th>

                  <th>Transaction ID</th>

                  <th>Status</th>

                  <th>Date</th>

                  <th>Action</th>
                </tr>
              </thead>

              <tbody>
                <tr>
                  <td>Subarna Ghosh</td>

                  <td>₹25,000</td>

                  <td>UPI</td>

                  <td>TXN12345678</td>

                  <td>
                    <span class="badge badge-paid"> Paid </span>
                  </td>

                  <td>15 Jun 2026</td>

                  <td>
                    <button class="btn btn-sm btn-outline-primary">View</button>
                  </td>
                </tr>

                <tr>
                  <td>Rahul Das</td>

                  <td>₹18,000</td>

                  <td>Card</td>

                  <td>TXN98765432</td>

                  <td>
                    <span class="badge badge-pending"> Pending </span>
                  </td>

                  <td>14 Jun 2026</td>

                  <td>
                    <button class="btn btn-sm btn-outline-primary">View</button>
                  </td>
                </tr>

                <tr>
                  <td>Ankita Roy</td>

                  <td>₹22,000</td>

                  <td>Bank</td>

                  <td>TXN11112222</td>

                  <td>
                    <span class="badge badge-failed"> Failed </span>
                  </td>

                  <td>13 Jun 2026</td>

                  <td>
                    <button class="btn btn-sm btn-outline-primary">View</button>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
