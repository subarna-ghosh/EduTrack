<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Payment Records</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="/assets/css/fee.css">
    <link rel="stylesheet" href="/assets/css/sidebar.css">
    <link rel="stylesheet" href="/assets/css/admin_navbar.css">
  </head>

  <body>
    <div class="container-fluid">
      <div class="row">
        <!-- SIDEBAR -->
        <%-include('../layouts/admin_sidebar')%>
        <div class="col-lg-10 main-content">
          <!-- navbar -->
          <div>
            <%-include('../layouts/admin_navbar')%>
          </div>
          <div>
      <div class="table-card">

        <!-- Top Bar -->
        <div class="top-bar">
          <form action="/web/view/payment/record" method="GET" class="d-flex gap-2">
            <input
            type="text"
            name="search"
            class="form-control"
            placeholder="Search Student..."
            />
            <button type="submit" class="search-btn-icon">
            <i class="fa-solid fa-magnifying-glass"></i>
            </button>        
          </form>

          <div class="d-flex gap-2">
            <a href="/web/view/payment/management" class="btn btn-secondary">
              ← Back to Dashboard
            </a>
          </div>
        </div>

        <!-- Table -->

        <div class="table-responsive">
          <table class="table table-bordered table-hover">
            <thead>
              <tr>
                <th>Sl.no</th>
                <th>Student Name</th>
                <th>Amount</th>
                <th>Payment Method</th>
                <th>Transaction ID</th>
                <th>Status</th>
                <th>Payment Date</th>
                <th width="180">Action</th>
              </tr>
            </thead>

            <tbody>
              <%if(findPayment.length===0){%>
                <tr>
                  <td colspan="6" style="text-align: center;">List is empty!</td>
                </tr>
              <%}else{%>
              <%findPayment.forEach((data,index)=>{%>
              <tr>
                <td><%= (currentPage - 1) * 3 + index + 1 %></td>
                <td><%=data.userInfo.name%></td>
                <td>₹<%=data.amount%></td>
                <td><%=data.paymentMethod%></td>
                <td><%=data.transactionId%></td>
                <td>
                    <%if(data.paymentStatus==="paid"){%>
                      <span class="badge status-paid"><%=data.paymentStatus%></span>
                    <%}else if(data.paymentStatus==="pending"){%>
                      <span class="badge status-pending"><%=data.paymentStatus%></span>
                    <%}else{%>
                      <span class="badge status-failed"><%=data.paymentStatus%></span>
                    <%}%>
                </td>
                <td><%=new Date(data.createdAt).toLocaleDateString("en-GB")%></td>
                <td>
                  <div class="action-btns">
                    <button class="btn btn-sm btn-info">View</button>
                  </div>
                </td>
              </tr>
              <%})%>
              <%}%>
            </tbody>
          </table>
        </div>

        <!-- Pagination -->

        <div class="pagination-wrapper">
          <nav>
            <ul class="pagination">
              <!-- previous page -->
              <li class="page-item <%= currentPage === 1? 'disabled':'' %>">
                <a class="page-link" href="/web/view/payment/record?page=<%= Math.max(1,currentPage-1) %>"> Previous </a>
              </li>

              <!-- Page Numbers -->
              <%for(let i=1;i<=totalPages;i++){%>
              <li class="page-item <%= currentPage === i? 'active':'' %>">
                <a class="page-link" href="/web/view/payment/record?page=<%=i%>"><%=i%></a>
              </li>
              <%}%>
              <!-- next page -->
              <li class="page-item <%= currentPage === totalPages? 'disabled':'' %>">
                <a class="page-link" href="/web/view/payment/record?page=<%= Math.min(totalPages,currentPage+1)%>"> Next </a>
              </li>
            </ul>
          </nav>
        </div>

      </div>
    </div>
        </div>
      </div>
    </div>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
