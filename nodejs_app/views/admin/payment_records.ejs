<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Payment Records</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/assets/css/fee.css">
  </head>

  <body>
    <div class="page-wrapper">
      <h2 class="page-title">Payment Records</h2>

      <div class="table-card">
        <!-- Top Bar -->

        <div class="top-bar">
          <input
            type="text"
            class="form-control search-box"
            placeholder="Search Student..."
          />

          <div class="d-flex gap-2">
            <a href="/web/view/payment/management" class="btn btn-secondary">
              ← Back
            </a>
          </div>
        </div>

        <!-- Table -->

        <div class="table-responsive">
          <table class="table table-bordered table-hover">
            <thead>
              <tr>
                <th>Sl.no</th>
                <th>Student Name</th>
                <th>Amount</th>
                <th>Payment Method</th>
                <th>Transaction ID</th>
                <th>Status</th>
                <th>Payment Date</th>
                <th width="180">Action</th>
              </tr>
            </thead>

            <tbody>
              <%findPayment.forEach((data,index)=>{%>
              <tr>
                <td><%=index+1%></td>
                <td><%=data.userInfo.name%></td>
                <td>₹<%=data.amount%></td>
                <td><%=data.paymentMethod%></td>
                <td><%=data.transactionId%></td>
                <td>
                    <%if(data.paymentStatus==="paid"){%>
                      <span class="badge status-paid"><%=data.paymentStatus%></span>
                    <%}else if(data.paymentStatus==="pending"){%>
                      <span class="badge status-pending"><%=data.paymentStatus%></span>
                    <%}else{%>
                      <span class="badge status-failed"><%=data.paymentStatus%></span>
                    <%}%>
                </td>
                <td><%=new Date(data.createdAt).toLocaleDateString("en-GB")%></td>
                <td>
                  <div class="action-btns">
                    <button class="btn btn-sm btn-info">View</button>
                  </div>
                </td>
              </tr>
              <%})%>
            </tbody>
          </table>
        </div>

        <!-- Pagination -->

        <div class="pagination-wrapper">
          <nav>
            <ul class="pagination">
              <li class="page-item">
                <a class="page-link" href="#"> Previous </a>
              </li>

              <li class="page-item active">
                <a class="page-link" href="#"> 1 </a>
              </li>

              <li class="page-item">
                <a class="page-link" href="#"> 2 </a>
              </li>

              <li class="page-item">
                <a class="page-link" href="#"> Next </a>
              </li>
            </ul>
          </nav>
        </div>
      </div>
    </div>
  </body>
</html>
