<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Assigned Students</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/assets/css/fee.css">
  </head>

  <body>
    <div class="page-wrapper">
      <h2 class="page-title">Assigned Fee</h2>

      <div class="table-card">
        <!-- Top Bar -->

        <div class="top-bar">
          <input
            type="text"
            class="form-control search-box"
            placeholder="Search Student..."
          />

          <div class="d-flex gap-2">
            <a href="/web/view/payment/management" class="btn btn-secondary">
              ← Back
            </a>

            <a href="/web/view/assign/fee" class="btn btn-primary">
              + Assign Fee
            </a>
          </div>
        </div>

        <!-- Table -->

        <div class="table-responsive">
          <table class="table table-bordered table-hover">
            <thead>
              <tr>
                <th>Sl.no</th>
                <th>Student Name</th>
                <th>Total Fee</th>
                <th>Paid Amount</th>
                <th>Due Amount</th>
                <th>Status</th>
                <th>Assigned Date</th>
                <th width="180">Action</th>
              </tr>
            </thead>

            <tbody>
              <%let status = ""%>
              <%listFee.forEach((data,index)=>{%>
              <tr>
                <td><%=index+1%></td>
                <td><%=data.userInfo.name%></td>
                <td>₹<%=data.totalFee%></td>
                <td>₹<%=data.paidAmount%></td>
                <td>₹<%=data.dueAmount%></td>
                <td>
                  <%if(data.dueAmount === data.totalFee){%>
                    <span class="status-failed">Unpaid</span>
                    <%}else if(data.dueAmount === 0){%>
                  <span class="status-paid">Paid</span>
                  <%}else{%>
                    <span class="status-pending">Partail</span>
                    <%}%>
                </td>
                <td><%=new Date(data.createdAt).toLocaleDateString("en-GB")%></td>
                <td>
                  <div class="action-btns">
                    <a href="/web/view/student/profile/<%=data._id %>" class="btn btn-sm btn-info">View</a>
                    <a href="/web/view/edit/student/<%=data._id %>" class="btn btn-sm btn-warning">Edit</a>
                    <a href="/web/delete/student/<%=data._id %>" class="btn btn-sm btn-danger">Delete</a>
                  </div>
                </td>
              </tr>
              <%})%>
            </tbody>
          </table>
        </div>

        <!-- Pagination -->

        <div class="pagination-wrapper">
          <nav>
            <ul class="pagination">
              <li class="page-item">
                <a class="page-link" href="#"> Previous </a>
              </li>

              <li class="page-item active">
                <a class="page-link" href="#"> 1 </a>
              </li>

              <li class="page-item">
                <a class="page-link" href="#"> 2 </a>
              </li>

              <li class="page-item">
                <a class="page-link" href="#"> Next </a>
              </li>
            </ul>
          </nav>
        </div>
      </div>
    </div>
  </body>
</html>
