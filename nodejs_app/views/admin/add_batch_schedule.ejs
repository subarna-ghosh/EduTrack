<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Create Batch Schedule</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
    />

    <style>
      body {
        background: #f4f6f9;
      }

      .schedule-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 0.15rem 1.75rem rgba(58, 59, 69, 0.15);
      }

      .page-title {
        font-weight: 700;
        color: #343a40;
      }

      .form-label {
        font-weight: 600;
      }

      .form-control,
      .form-select {
        height: 48px;
        border-radius: 10px;
      }

      textarea.form-control {
        height: auto;
      }

      .header-icon {
        width: 65px;
        height: 65px;
        background: #0d6efd;
        color: white;
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 28px;
        margin: auto;
      }

      .btn-save {
        min-width: 170px;
      }
    </style>
  </head>

  <body>
    <div class="container py-5">
      <div class="row justify-content-center">
        <div class="col-lg-9">
          <div class="card schedule-card">
            <div class="card-body p-5">
              <div class="text-center mb-4">
                <h2 class="page-title">Create Batch Schedule</h2>

                <p class="text-muted">
                  Schedule classes for a particular batch.
                </p>
              </div>

              <form action="#" method="POST">
                <!-- Batch -->

                <div class="mb-3">
                  <label class="form-label"> Batch </label>

                  <select class="form-select" required>
                    <option value="">Select Batch</option>

                    <option>MERN Stack - Batch A</option>

                    <option>Frontend Development - Batch B</option>

                    <option>PHP Laravel - Batch C</option>
                  </select>
                </div>

                <!-- Faculty -->

                <div class="mb-3">
                  <label class="form-label"> Faculty </label>

                  <select class="form-select" required>
                    <option value="">Select Faculty</option>

                    <option>Rahul Sharma</option>

                    <option>Amit Roy</option>

                    <option>Sneha Das</option>
                  </select>
                </div>

                <!-- Day -->

                <div class="mb-3">
                  <label class="form-label"> Day </label>

                  <select class="form-select" required>
                    <option value="">Select Day</option>

                    <option>Monday</option>
                    <option>Tuesday</option>
                    <option>Wednesday</option>
                    <option>Thursday</option>
                    <option>Friday</option>
                    <option>Saturday</option>
                    <option>Sunday</option>
                  </select>
                </div>

                <!-- Time -->

                <div class="row">
                  <div class="col-md-6 mb-3">
                    <label class="form-label"> Start Time </label>

                    <input type="time" class="form-control" required />
                  </div>

                  <div class="col-md-6 mb-3">
                    <label class="form-label"> End Time </label>

                    <input type="time" class="form-control" required />
                  </div>
                </div>

                <!-- Topic -->

                <div class="mb-3">
                  <label class="form-label"> Today's Topic </label>

                  <input
                    type="text"
                    class="form-control"
                    placeholder="Example : React Components"
                    required
                  />
                </div>

                <!-- Meeting Link -->

                <div class="mb-3">
                  <label class="form-label"> Google Meet / Zoom Link </label>

                  <input
                    type="url"
                    class="form-control"
                    placeholder="https://meet.google.com/..."
                  />
                </div>

                <!-- Description -->

                <div class="mb-4">
                  <label class="form-label"> Description </label>

                  <textarea
                    class="form-control"
                    rows="4"
                    placeholder="Any class instructions..."
                  ></textarea>
                </div>

                <!-- Buttons -->

                <div class="d-flex gap-3">
                  <button type="submit" class="btn btn-primary btn-save">
                    <i class="fa-solid fa-floppy-disk me-2"></i>

                    Save Schedule
                  </button>

                  <a href="#" class="btn btn-secondary btn-save">
                    <i class="fa-solid fa-arrow-left me-2"></i>

                    Back
                  </a>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
