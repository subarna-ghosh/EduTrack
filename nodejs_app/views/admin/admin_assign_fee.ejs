<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Assign Fee</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
    />
    <link rel="stylesheet" href="/assets/css/admin_assign_fee.css">
    <link rel="stylesheet" href="/assets/css/sidebar.css">
    <link rel="stylesheet" href="/assets/css/admin_navbar.css">
  </head>

  <body>
    <div class="container">
      <div class="row justify-content-center">
        <!-- SIDEBAR -->
        <%-include('../layouts/admin_sidebar')%>
        <div class="col-lg-10 main-content">
          <!-- navbar -->
          <div>
            <%-include('../layouts/admin_navbar')%>
          </div>
          <div class="card form-card">
            <div class="card-body p-4">
              <div class="info-box">
                <strong>Note:</strong>

                Assign the total course fee for the selected student. Paid
                amount will start from ₹0.
              </div>

              <form action="/web/create/fee" method="POST">
                <!-- Student -->

                <div class="mb-3">
                  <label class="form-label"> Select Student </label>

                  <select name="studentId" class="form-select" required>
                    <option value="">Select Student</option>
                    <%listStudents.forEach((val)=>{%>
                    <option value="<%=val._id%>"><%=val.userInfo.name%> (<%=val.courseInfo.courseName%>)</option>
                    <%})%>
                  </select>
                </div>

                <!-- Total Fee -->

                <div class="mb-3">
                  <label class="form-label"> Total Course Fee </label>

                  <input
                    type="number"
                    name="totalFee"
                    class="form-control"
                    placeholder="Enter total fee"
                    required
                  />
                </div>

                <!-- Paid Amount -->

                <div class="mb-3">
                  <label class="form-label"> Initial Paid Amount </label>

                  <input
                    type="number"
                    name="paidAmount"
                    class="form-control"
                    value="0"
                    readonly
                  />
                </div>

                <!-- Buttons -->

                <div class="d-flex gap-3">
                  <button type="submit" class="btn btn-primary">
                    <i class="fa-solid fa-money-bill-wave me-2"></i>
                    Assign Fee
                  </button>

                  <a href="/web/view/assigned/fee/student" class="btn btn-secondary">
                    <i class="fa-solid fa-arrow-left me-2"></i>
                    Back to Assigned Fee List
                  </a>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
