<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Batch List</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <link
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/assets/css/batch.css" />
  </head>

  <body>
    <div class="container py-5">
      <!-- Header -->

      <div class="d-flex mb-4">
        <div>
          <h2 class="page-title">Batch Management</h2>
          <p class="text-muted mb-0">Manage all batches from here</p>
        </div>
      </div>

      <!-- Card -->
      <div class="card page-card">

        <div class="card-body">

          <div class="top-bar">
           <!-- Search -->
            <form action="/web/view/add/batch/list" method="GET" class="d-flex gap-2">
              <input
              name="search"
              class="form-control"
              placeholder="Search Batch..."
              type="text"
               />
              <button type="submit" class="search-btn-icon">
                <i class="fa-solid fa-magnifying-glass"></i>
              </button>        
            </form>

           <!-- Buttons -->
           <div class="d-flex gap-2">
              <a href="/web/view/admin/dashboard" class="btn btn-secondary">
              <i class="fa-solid fa-arrow-left me-2"></i> Dashboard </a>
              <a href="/web/view/add/batch" class="btn btn-primary">
                <i class="fa-solid fa-plus me-2"></i>Create Batch
              </a>
            </div>
          </div>

          <!-- connect-flash -->
        <% if (success.length > 0) { %>
          <div id="successAlert" class="alert alert-info">
             <%= success[0] %>
          </div>
        <% } %>

        <% if (error.length > 0) { %>
          <div id="successAlert" class="alert alert-danger">
             <%= error[0] %>
          </div>
        <% } %>

          <!-- Table -->
          <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle">
              <thead class="table-light">
                <tr>
                  <th>Sl.no</th>
                  <th>Batch Name</th>
                  <th>Course</th>
                  <th>Faculty</th>
                  <th>Start Date</th>
                  <th>End Date</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
 
              <tbody>
                <%if(findBatch.length===0){%>
                <tr>
                  <td colspan="8" style="text-align: center;">List is empty!</td>
                </tr>
                <%}else{%>

                <%findBatch.forEach((val,index)=>{%>
                <tr>
                  <td><%= (currentPage - 1) * 3 + index + 1 %></td>
                  <td><%=val.batchName%></td>
                  <td><%=val.courseList.courseName%></td>
                  <td><%= val.userInfo?.name || "No Faculty" %></td>
                  <td><%=new Date(val.startDate).toLocaleDateString("en-GB")%></td>
                  <td><%=new Date(val.endDate).toLocaleDateString("en-GB")%></td>
                  <td>
                    <span class="badge bg-success"><%=val.status%></span>
                  </td>
                  <td>
                    <div class="d-flex gap-2">
                      <a href="/web/view/edit/batch/<%=val._id%>" class="btn btn-warning btn-sm action-btn">
                        <i class="fa-solid fa-pen"></i>
                      </a>

                      <a href="/web/delete/batch/<%=val._id%>" class="btn btn-danger btn-sm action-btn">
                        <i class="fa-solid fa-trash"></i>
                      </a>
                    </div>
                  </td>
                </tr>
                <%})%>  
                <%}%>            
              </tbody>
            </table>
          </div>

          <!-- Pagination -->
        <div class="pagination-wrapper d-flex justify-content-end">
          <nav>
            <ul class="pagination">
              <!-- previous page -->
              <li class="page-item <%= currentPage === 1? 'disabled':'' %>">
                <a class="page-link" href="/web/view/add/batch/list?page=<%= Math.max(1,currentPage-1) %>"> Previous </a>
              </li>

              <!-- Page Numbers -->
              <%for(let i=1;i<=totalPages;i++){%>
              <li class="page-item <%= currentPage === i? 'active':'' %>">
                <a class="page-link" href="/web/view/add/batch/list?page=<%=i%>"><%=i%></a>
              </li>
              <%}%>
              <!-- next page -->
              <li class="page-item <%= currentPage === totalPages? 'disabled':'' %>">
                <a class="page-link" href="/web/view/add/batch/list?page=<%= Math.min(totalPages,currentPage+1)%>"> Next </a>
              </li>
            </ul>
          </nav>
        </div> 

        </div>

        </div>
      </div>
    </div>
    <script>
      setTimeout(() => {
        const alert = document.getElementById("successAlert");
          if (alert) {
            alert.remove();
          }
        }, 1000); // 1 seconds
    </script>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
