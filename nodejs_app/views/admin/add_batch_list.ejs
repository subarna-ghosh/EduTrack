<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Batch List</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <link
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
      rel="stylesheet"
    />

    <style>
      body {
        background: #f5f7fb;
      }

      .page-card {
        border: none;
        border-radius: 18px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
      }

      .table th {
        font-weight: 600;
        color: white;
        background: #0d6efd;
        vertical-align: middle;
      }
      .table td {
        vertical-align: middle;
      }

      .page-title {
        font-weight: 700;
      }

      .action-btn {
        width: 35px;
        height: 35px;
        display: flex;
        justify-content: center;
        align-items: center;
      }
    </style>
  </head>

  <body>
    <div class="container py-5">
      <!-- Header -->

      <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
          <h2 class="page-title">Batch Management</h2>

          <p class="text-muted mb-0">Manage all batches from here</p>
        </div>

        <div class="d-flex gap-2">
          <a href="/web/view/admin/dashboard" class="btn btn-secondary">
            <i class="fa-solid fa-arrow-left me-2"></i>
            Dashboard
          </a>

          <a href="/web/view/add/batch" class="btn btn-primary">
            <i class="fa-solid fa-plus me-2"></i>
            Create Batch
          </a>
        </div>
      </div>

      <!-- Card -->

      <div class="card page-card">
        <div class="card-body">
          <!-- Search -->

          <div class="row mb-4">
            <div class="col-md-4">
              <input
                type="text"
                class="form-control"
                placeholder="Search Batch..."
              />
            </div>
          </div>

          <!-- Table -->

          <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle">
              <thead class="table-light">
                <tr>
                  <th>#</th>
                  <th>Batch Name</th>
                  <th>Course</th>
                  <th>Faculty</th>
                  <th>Start Date</th>
                  <th>End Date</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
 
              <tbody>
                <%findBatch.forEach((val,index)=>{%>
                <tr>
                  <td><%=index+1%></td>
                  <td><%=val.batchName%></td>
                  <td><%=val.courseList.courseName%></td>
                  <td><%= val.userInfo?.name || "No Faculty" %></td>
                  <td><%=new Date(val.startDate).toLocaleDateString("en-GB")%></td>
                  <td><%=new Date(val.endDate).toLocaleDateString("en-GB")%></td>
                  <td>
                    <span class="badge bg-success"><%=val.status%></span>
                  </td>
                  <td>
                    <div class="d-flex gap-2">
                      <a href="#" class="btn btn-warning btn-sm action-btn">
                        <i class="fa-solid fa-pen"></i>
                      </a>

                      <a href="#" class="btn btn-danger btn-sm action-btn">
                        <i class="fa-solid fa-trash"></i>
                      </a>
                    </div>
                  </td>
                </tr>
                <%})%>              
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
