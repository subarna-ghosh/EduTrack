<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Edit Faculty</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
    />
    <link rel="stylesheet" href="/assets/css/faculty.css">
  </head>

  <body>
    <div class="container py-5">
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <div class="card form-card">
            <!-- Header -->

            <div class="card-header bg-white py-3">
              <h3 class="page-title mb-0">Edit Faculty</h3>
            </div>

            <!-- Body -->

            <div class="card-body p-4">
              <form
                action="/web/update/faculty/<%=showData[0]._id%>"
                method="POST"
                enctype="multipart/form-data"
              >
                <!-- Hidden Faculty Role -->

                <input type="hidden" name="roleId" value="" />

                <!-- Profile Image -->

                <div class="mb-4 text-center">
                  <div class="image-preview mx-auto">
                    <i class="fa-solid fa-user"></i>

                    <img id="previewImage" />
                  </div>

                  <label class="form-label"> Profile Image </label>

                  <input
                    type="file"
                    name="profileImage"
                    class="form-control"
                    accept="profileImage/*"
                    onchange="preview(event)"
                  />
                </div>

                <!-- Faculty Name -->

                <div class="mb-3">
                  <label class="form-label"> Faculty Name </label>

                  <input
                    type="text"
                    name="name"
                    class="form-control"
                    placeholder="Enter faculty name"
                    value="<%= showData[0].userInfo.name %>"
                    required
                  />
                </div>

                <!-- Email -->

                <div class="mb-3">
                  <label class="form-label"> Email Address </label>

                  <input
                    type="email"
                    name="email"
                    class="form-control"
                    placeholder="Enter email address"
                    value="<%=showData[0].userInfo.email%>"
                    required
                  />
                </div>

                <!-- Phone -->

                <div class="mb-3">
                  <label class="form-label"> Phone Number </label>

                  <input
                    type="text"
                    name="phone"
                    class="form-control"
                    placeholder="Enter phone number"
                    value="<%=showData[0].phone%>"
                    required
                  />
                </div>

                <!-- Password -->

                <div class="mb-3">
                  <label class="form-label"> Password </label>

                  <input
                    type="password"
                    name="password"
                    class="form-control"
                    placeholder="Enter password"
                    required
                  />
                </div>

                <!-- Address -->

                <div class="mb-3">
                  <label class="form-label"> Address </label>

                  <textarea
                    name="address"
                    rows="3"
                    class="form-control"
                    placeholder="Enter address"
                    required
                  ><%=showData[0].address%></textarea>
                </div>

                <!-- Department -->

                <div class="mb-3">
                  <label class="form-label"> Department </label>

                  <select name="deptId" class="form-select" required>
                    <option value="">Select Department</option>

                    <%selectDept.forEach((val)=>{%>
                    <option value="<%=val._id%>">
                      <%=val.deptName%>
                    </option>
                    <%})%>
                  </select>
                </div>

                <!-- Experience -->

                <div class="mb-3">
                  <label class="form-label"> Experience (Years) </label>

                  <input
                    type="number"
                    name="experience"
                    class="form-control"
                    placeholder="Enter experience"
                    value="<%=showData[0].experience%>"
                    min="0"
                    required
                  />
                </div>

                <!-- Status -->

                <div class="mb-4">
                  <label class="form-label"> Status </label>

                  <select name="status" class="form-select">
                    <option value="active">Active</option>

                    <option value="inactive">Inactive</option>
                  </select>
                </div>

                <!-- Buttons -->

                <div class="d-flex gap-3">
                  <button type="submit" class="btn btn-primary">
                    <i class="fa-solid fa-user-plus me-2"></i>
                    Update Faculty
                  </button>

                  <a
                    href="/web/view/add/faculty/list"
                    class="btn btn-secondary"
                  >
                    <i class="fa-solid fa-arrow-left me-2"></i>
                    Back
                  </a>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script>
      function preview(event) {
        const img = document.getElementById("previewImage");

        img.src = URL.createObjectURL(event.target.files[0]);

        img.style.display = "block";

        document.querySelector(".image-preview i").style.display = "none";
      }
    </script>
  </body>
</html>
