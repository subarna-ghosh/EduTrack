<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Student Details</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/assets/css/student.css" />
  </head>

  <body>
    <div class="container py-5">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h3>Student Details</h3>

        <a href="/web/view/add/student/list" class="btn btn-secondary">
          <i class="fa-solid fa-arrow-left me-1"></i> Back
        </a>
      </div>

      <div class="card profile-card p-4">
        <div class="text-center mb-4">
          <img src="<%=findStudent[0].profileImage%>" class="profile-img" />
          <h4 class="mt-3"><%=findStudent[0].userInfo.name%></h4>
          <p class="text-muted"><%=findStudent[0].courseInfo.courseName%></p>
        </div>

        <div class="row">
          <div class="col-md-6 mb-3">
            <div class="label">Email</div>
            <div class="value"><%=findStudent[0].userInfo.email%></div>
          </div>

          <div class="col-md-6 mb-3">
            <div class="label">Phone</div>
            <div class="value"><%=findStudent[0].phone%></div>
          </div>

          <div class="col-md-6 mb-3">
            <div class="label">Address</div>
            <div class="value"><%=findStudent[0].address%></div>
          </div>

          <div class="col-md-6 mb-3">
            <div class="label">Batch</div>
            <div class="value"><%=findStudent[0].batchInfo.batchName%></div>
          </div>

          <div class="col-md-6 mb-3">
            <div class="label">Course</div>
            <div class="value"><%=findStudent[0].courseInfo.courseName%></div>
          </div>

          <div class="col-md-6 mb-3">
            <div class="label">Student Code</div>
            <div class="value"><%=findStudent[0].studentCode%></div>
          </div>

          <div class="col-md-6 mb-3">
            <div class="label">Joining Date</div>
            <div class="value">
              <%=new
              Date(findStudent[0].batchInfo.startDate).toLocaleDateString("en-GB")%>
            </div>
          </div>

          <div class="col-md-6 mb-3">
            <div class="label">Status</div>
            <div class="value">
              <span class="status-active"><%=findStudent[0].status%></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
