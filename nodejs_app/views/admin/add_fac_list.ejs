<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Faculty List</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="/assets/css/faculty.css">
    <link rel="stylesheet" href="/assets/css/sidebar.css">
  </head>

  <body>

    <div class="container-fluid">
      <div class="row">
        <!-- SIDEBAR -->
        <%-include('../layouts/admin_sidebar')%>
        
        <div class="col-lg-8 main-content">
           <div class="page-wrapper ">
      <h2 class="page-title">Faculty List</h2>

      <div class="faculty-card">

        <div class="top-bar">
          <form action="/web/view/add/faculty/list" method="GET" class="d-flex gap-2">
            <input
              type="text"
              name="search"
              class="form-control search-box"
              placeholder="Search Faculty..."
            />
            <button type="submit" class="search-btn-icon">
            <i class="fa-solid fa-magnifying-glass"></i>
            </button>            
          </form>

          <div class="d-flex gap-2">
            <!-- Add Department Button -->
            <button
              class="btn btn-success"
              data-bs-toggle="modal"
              data-bs-target="#addDeptModal"
            >
              + Add Department
            </button>

            <a href="/web/view/add/faculty" class="btn btn-primary">
              + Add Faculty
            </a>
          </div>

        </div>

        <!-- connect-flash -->
        <% if (success.length > 0) { %>
          <div id="successAlert" class="alert alert-info">
             <%= success[0] %>
          </div>
        <% } %>

        <% if (error.length > 0) { %>
          <div id="successAlert" class="alert alert-danger">
             <%= error[0] %>
          </div>
        <% } %>

        <div class="table-responsive">
          <table class="table table-bordered table-hover">
            <thead>
              <tr>
                <th>Sl.no</th>
                <th>Photo</th>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Department</th>
                <th>Experience</th>
                <th>Status</th>
                <th width="180">Action</th>
              </tr>
            </thead>

            <tbody>
              <%if(getFacultyInfo.length===0){%>
                <tr>
                  <td colspan="9" style="text-align: center;">List is empty!</td>
                </tr>
              <%}else{%>
              <%getFacultyInfo.forEach((faculty,index)=>{%>
              <tr>
                <td><%= (currentPage - 1) * 3 + index + 1 %></td>
                <td>
                  <img
                    src="<%=faculty.profileImage%>"
                    class="faculty-image"
                    alt=""
                  />
                </td>
                <td><%=faculty.userInfo.name%></td>
                <td><%=faculty.userInfo.email%></td>
                <td><%=faculty.phone%></td>
                <td><%=faculty.deptInfo.deptName%></td>
                <td><%=faculty.experience%> Years</td>
                <td>
                  <span class="status-active"><%=faculty.status%></span>
                </td>
                <td>
                  <div class="action-btns">
                    <a href="/web/faculty/profile/view/<%=faculty._id %>" class="btn btn-sm btn-info">View</a>
                    <a href="/web/edit/faculty/view/<%=faculty._id %>" class="btn btn-sm btn-warning">Edit</a>
                    <a href="/web/delete/faculty/<%=faculty._id %>" class="btn btn-sm btn-danger">Delete</a>
                  </div>
                </td>
              </tr>
              <%})%>
              <%}%>
            </tbody>
          </table>
        </div>

        <!-- Pagination -->
        <div class="pagination-wrapper">
          <nav>
            <ul class="pagination">
              <!-- previous page -->
              <li class="page-item <%= currentPage === 1? 'disabled':'' %>">
                <a class="page-link" href="/web/view/add/faculty/list?page=<%= Math.max(1,currentPage-1) %>"> Previous </a>
              </li>

              <!-- Page Numbers -->
              <%for(let i=1;i<=totalPages;i++){%>
              <li class="page-item <%= currentPage === i? 'active':'' %>">
                <a class="page-link" href="/web/view/add/faculty/list?page=<%=i%>"><%=i%></a>
              </li>
              <%}%>
              <!-- next page -->
              <li class="page-item <%= currentPage === totalPages? 'disabled':'' %>">
                <a class="page-link" href="/web/view/add/faculty/list?page=<%= Math.min(totalPages,currentPage+1)%>"> Next </a>
              </li>
            </ul>
          </nav>
        </div>

      </div>
    </div>
        </div>
      </div>
    </div>
  
    <!-- modal -->
    <div
      class="modal fade"
      id="addDeptModal"
      tabindex="-1"
      aria-labelledby="addDeptModalLabel"
      aria-hidden="true"
    >
      <div class="modal-dialog">
        <div class="modal-content">
          <!-- Header -->
          <div class="modal-header">
            <h5 class="modal-title" id="addDeptModalLabel">Add Department</h5>
            <button
              type="button"
              class="btn-close"
              data-bs-dismiss="modal"
            ></button>
          </div>

          <!-- Body -->
          <div class="modal-body">
            <form id="deptForm" action="/web/save/department" method="post">
              <div class="mb-3">
                <label class="form-label">Department Name</label>
                <input
                  type="text"
                  class="form-control"
                  name="deptName"
                  placeholder="Enter department name"
                />
              </div>

              <button type="submit" class="btn btn-primary">
                Save Department
              </button>
            </form>
          </div>

          <!-- Footer -->
          <div class="modal-footer">
            <button
              type="button"
              class="btn btn-secondary"
              data-bs-dismiss="modal"
            >
              Cancel
            </button>
          </div>
        </div>
      </div>
    </div>
    <script>
      setTimeout(() => {
        const alert = document.getElementById("successAlert");
          if (alert) {
            alert.remove();
          }
        }, 1000); // 1 seconds
    </script>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
