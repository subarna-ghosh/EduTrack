<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Update Student</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
    />
    <link rel="stylesheet" href="/assets/css/student.css">
    <link rel="stylesheet" href="/assets/css/sidebar.css">
  </head>

  <body>
    <div class="container py-5">
      <div class="row">

        <!-- SIDEBAR -->
        <%-include('../layouts/admin_sidebar')%>

        <div class="col-lg-8 main-content">
          <div class="card form-card">
            <!-- Header -->

            <div class="card-header bg-white py-3">
              <h3 class="page-title mb-0">Update Student</h3>
            </div>

            <!-- Body -->

            <div class="card-body p-4">
              <form
                action="/web/update/student/<%=findStudent[0]._id%>"
                method="POST"
                enctype="multipart/form-data"
              >
                <!-- Profile Image -->

                <div class="text-center mb-4">
                  <div class="image-preview">
                    <i class="fa-solid fa-user"></i>

                    <img id="previewImage" />
                  </div>

                  <label class="form-label mt-3"> Profile Image </label>

                  <input
                    type="file"
                    name="profileImage"
                    class="form-control"
                    accept="image/*"
                    onchange="preview(event)"
                  />
                </div>

                <!-- Name -->

                <div class="mb-3">
                  <label class="form-label"> Student Name </label>

                  <input
                    type="text"
                    name="name"
                    class="form-control"
                    placeholder="Enter student name"
                    value="<%=findStudent[0].userInfo.name%>"
                    required
                  />
                </div>

                <!-- Student Code -->

                <div class="mb-3">
                  <label class="form-label"> Student Code </label>

                  <input
                    type="text"
                    name="studentCode"
                    class="form-control"
                    placeholder="Ex: STU001"
                    value="<%=findStudent[0].studentCode%>"
                    required
                  />
                </div>

                <!-- Email -->

                <div class="mb-3">
                  <label class="form-label"> Email Address </label>

                  <input
                    type="email"
                    name="email"
                    class="form-control"
                    placeholder="Enter email address"
                    value="<%=findStudent[0].userInfo.email%>"
                    required
                  />
                </div>

                <!-- Password -->

                <div class="mb-3">
                  <label class="form-label"> Password </label>

                  <input
                    type="password"
                    name="password"
                    class="form-control"
                    placeholder="Enter password"
                    required
                  />
                </div>

                <!-- Phone -->

                <div class="mb-3">
                  <label class="form-label"> Phone Number </label>

                  <input
                    type="text"
                    name="phone"
                    class="form-control"
                    placeholder="Enter phone number"
                    value="<%=findStudent[0].phone%>"
                    required
                  />
                </div>

                <!-- Address -->

                <div class="mb-3">
                  <label class="form-label"> Address </label>

                  <textarea
                    name="address"
                    rows="3"
                    class="form-control"
                    placeholder="Enter address"
                    value="<%=findStudent[0].address%>"
                    required
                  ><%=findStudent[0].address%></textarea>
                </div>

                <!-- Batch -->

                <div class="mb-3">
                  <label class="form-label"> Batch </label>

                  <select name="batchId" class="form-select" required>
                    <option value="">Select Batch</option>
                    <%findBatch.forEach((batch)=>{%>
                    <option value="<%=batch._id%>"><%=batch.batchName%></option>
                    <%})%>
                  </select>
                </div>

                <!-- Status -->

                <div class="mb-4">
                  <label class="form-label"> Status </label>

                  <select name="status" class="form-select">
                    <option value="active">Active</option>

                    <option value="inactive">Inactive</option>
                  </select>
                </div>

                <!-- Buttons -->

                <div class="d-flex gap-3">
                  <button type="submit" class="btn btn-primary">
                    <i class="fa-solid fa-user-plus me-2"></i>
                    Update Student
                  </button>

                  <a
                    href="/web/view/add/student/list"
                    class="btn btn-secondary"
                  >
                    <i class="fa-solid fa-arrow-left me-2"></i>
                    Back
                  </a>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script>
      function preview(event) {
        const img = document.getElementById("previewImage");

        img.src = URL.createObjectURL(event.target.files[0]);

        img.style.display = "block";

        document.querySelector(".image-preview i").style.display = "none";
      }
    </script>
  </body>
</html>
