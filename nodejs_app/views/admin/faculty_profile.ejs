<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Faculty Details</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/assets/css/faculty.css" />
    <link rel="stylesheet" href="/assets/css/sidebar.css">
    <link rel="stylesheet" href="/assets/css/admin_navbar.css">
  </head>

  <body>
    <div class="container-fluid">
      <div class="row">
        <!-- SIDEBAR -->
        <%-include('../layouts/admin_sidebar')%>
        <div class="col-lg-10 main-content">
          <!-- navbar -->
          <div>
            <%-include('../layouts/admin_navbar')%>
          </div>
          <div class="d-flex justify-content-end align-items-center mb-4">

            <a href="/web/view/add/faculty/list" class="btn btn-secondary">
              <i class="fa-solid fa-arrow-left me-1"></i> Back
            </a>
          </div>

          <div class="card profile-card p-4">
            <div class="text-center mb-4">
              <img
                src="<%=showFacultyProfile[0].profileImage%>"
                class="profile-img"
              />
              <h4 class="mt-3"><%=showFacultyProfile[0].userInfo.name%></h4>
              <p class="text-muted">
                <%=showFacultyProfile[0].deptInfo.deptName%>
              </p>
            </div>

            <div class="row">
              <div class="col-md-6 mb-3">
                <div class="label">Email</div>
                <div class="value">
                  <%=showFacultyProfile[0].userInfo.email%>
                </div>
              </div>

              <div class="col-md-6 mb-3">
                <div class="label">Phone</div>
                <div class="value"><%=showFacultyProfile[0].phone%></div>
              </div>

              <div class="col-md-6 mb-3">
                <div class="label">Experience</div>
                <div class="value">
                  <%=showFacultyProfile[0].experience%> years
                </div>
              </div>

              <div class="col-md-6 mb-3">
                <div class="label">Status</div>
                <div class="value">
                  <span class="status-active"
                    ><%=showFacultyProfile[0].status%></span
                  >
                </div>
              </div>

              <div class="col-12 mb-3">
                <div class="label">About</div>
                <div class="value">
                  Experienced faculty in web development specializing in MERN
                  stack, frontend architecture, and UI/UX systems.
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
