<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Attendance List</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/assets/css/attendance.css" />
  </head>

  <body>
    <div class="page-wrapper">
      <h2 class="page-title">Attendance List</h2>

      <div class="attendance-card">
        <div class="top-bar">
          <form action="/web/view/attendance/list" method="GET" class="d-flex gap-2">
            <input type="hidden" name="courseId" value="<%= courseId || '' %>"/>
            <input type="hidden" name="batchId" value="<%= batchId || '' %>"/>
            <input type="hidden" name="attendanceDate" value="<%= attendanceDate || '' %>"/>
            <input type="text" name="search" value="<%= search || '' %>" class="form-control search-box" placeholder="Search Student..."/>
            <button type="submit" class="search-btn-icon">
              <i class="fa-solid fa-magnifying-glass"></i>
            </button>

          </form>

          <div class="d-flex gap-2">
            <a href="/web/view/admin/dashboard" class="btn btn-secondary"
              ><i class="fa-solid fa-arrow-left me-2"></i> Back to Dashboard</a
            >
            <a href="/web/view/mark/attendance" class="btn btn-primary"> + Mark Attendance </a>
          </div>

        </div>

        <!-- connect-flash -->
        <% if (success.length > 0) { %>
          <div id="successAlert" class="alert alert-info">
             <%= success[0] %>
          </div>
        <% } %>

        <% if (error.length > 0) { %>
          <div id="successAlert" class="alert alert-danger">
             <%= error[0] %>
          </div>
        <% } %>

        <div class="summary-box">
          <div class="summary-card">
            <h4><%=totalStudents%></h4>
            <p>Total Students</p>
          </div>

          <div class="summary-card">
            <h4><%=totalPresent%></h4>
            <p>Present</p>
          </div>

          <div class="summary-card">
            <h4><%=totalAbsent%></h4>
            <p>Absent</p>
          </div>

          <div class="summary-card">
            <h4><%=totalLate%></h4>
            <p>Late</p>
          </div>
        </div>

        <div class="filter-section">
          <form action="/web/view/attendance/list" method="GET">
            <div class="row">
      
              <div class="col-md-3">
                <label class="form-label">Course</label>

                <select class="form-select" name="courseId">
                  <option value="">Select Course</option>
                  <%courses.forEach((val)=>{%>
                  <option value="<%=val._id%>"><%=val.courseName%></option>
                  <%})%>
                </select>
              </div>

              <div class="col-md-3">
                <label class="form-label">Batch</label>

                <select class="form-select" name="batchId">
                  <option value="">Select Batch</option>
                  <%batches.forEach((data)=>{%>
                  <option value="<%=data._id%>"><%=data.batchName%></option>
                  <%})%>
                </select>
              </div>

              <div class="col-md-3">
                <label class="form-label">Date</label>

                <input type="date" class="form-control" name="attendanceDate"/>
              </div>

              <div class="col-md-3 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">
                  Search Attendance
                </button>
              </div>

            </div>
          </form>
        </div>

        <div class="table-responsive">
          <table class="table table-bordered table-hover">
            <thead>
              <tr>
                <th>SL</th>
                <th>Student Name</th>
                <th>Student Code</th>
                <th>Course</th>
                <th>Batch</th>
                <th>Date</th>
                <th>Status</th>
                <th>Action</th>
              </tr>
            </thead>

            <tbody>
              <%if(students.length>0){%>
              <%students.forEach((val,index)=>{%>
              <tr>
                <td><%=index+1%></td>
                <td><%=val.userInfo.name%></td>
                <td><%=val.studentInfo.studentCode%></td>
                <td><%=val.courseInfo.courseName%></td>
                <td><%=val.batchInfo.batchName%></td>
                <td><%=new Date(attendanceDate).toLocaleDateString("en-GB")%></td>
                <td>
                  <span class="status-present"><%=val.status%></span>
                </td>
                <td>
                  <div class="action-btns">
                    <button class="btn btn-sm btn-info">View</button>
                  </div>
                </td>
              </tr>
              <%})%>
              <%}else{%>
                <tr>
                  <td colspan="8" class="text-center">No data to show presently!</td>
                </tr>
                <%}%>
            </tbody>
          </table>
        </div>

        <!-- Pagination -->
        <div class="pagination-wrapper">
          <nav>
            <ul class="pagination">
              <!-- previous page -->
              <li class="page-item <%= currentPage === 1? 'disabled':'' %>">
                <a class="page-link" href="/web/view/add/student/list?page=<%= Math.max(1,currentPage-1) %>"> Previous </a>
              </li>

              <!-- Page Numbers -->
              <%for(let i=1;i<=totalPages;i++){%>
              <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                <a class="page-link" href="/web/view/add/student/list?page=<%=i%>"><%=i%></a>
              </li>
              <%}%>
              <!-- next page -->
              <li class="page-item <%= currentPage === totalPages? 'disabled':'' %>">
                <a class="page-link" href="/web/view/add/student/list?page=<%= Math.min(totalPages,currentPage+1)%>"> Next </a>
              </li>
            </ul>
          </nav>
        </div>

      </div>
    </div>
     <script>
      setTimeout(() => {
        const alert = document.getElementById("successAlert");
          if (alert) {
            alert.remove();
          }
        }, 2000); // 2 seconds
    </script>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
      crossorigin="anonymous"
    ></script>
  </body>
</html>

