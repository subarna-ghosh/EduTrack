<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Announcement Details</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
    />
    <link rel="stylesheet" href="/assets/css/announcement.css" />
    <link rel="stylesheet" href="/assets/css/sidebar.css">
    <link rel="stylesheet" href="/assets/css/admin_navbar.css">
  </head>

  <body>
    <div class="container">
      <div class="row justify-content-center">
         <!-- SIDEBAR -->
        <%-include('../layouts/admin_sidebar')%>
        <div class="col-lg-10 main-content">
          <!-- navbar -->
          <div>
            <%-include('../layouts/admin_navbar')%>
          </div>
          <div class="card details-card">
            <div class="card-body p-4">
              <div class="info-box">
                View complete information about the announcement.
              </div>

              <!-- Title -->
              <div class="mb-4">
                <label class="detail-label"> Announcement Title </label>

                <div class="detail-value"><%=showAnnouncements[0].title%></div>
              </div>

              <!-- Type -->
              <div class="mb-4">
                <label class="detail-label"> Announcement Type </label>

                <div class="detail-value"><%=showAnnouncements[0].announcementType%></div>
              </div>

              <!-- Batch -->
              <div class="mb-4">
                <label class="detail-label"> Assigned Batch </label>

                <div class="detail-value"><%= showAnnouncements[0].batchInfo ? showAnnouncements[0].batchInfo.batchName : "-" %></div>
              </div>

              <!-- Status -->
              <div class="mb-4">
                <label class="detail-label"> Status </label>

                <div>
                  <span class="badge bg-success px-3 py-2"><%=showAnnouncements[0].status%></span>
                </div>
              </div>

              <!-- Created By -->
              <div class="mb-4">
                <label class="detail-label"> Created By </label>

                <div class="detail-value"><%=showAnnouncements[0].userInfo.name%></div>
              </div>

              <!-- Created Date -->
              <div class="mb-4">
                <label class="detail-label"> Created On </label>

                <div class="detail-value"><%=new Date(showAnnouncements[0].createdAt).toLocaleDateString("en-GB")%></div>
              </div>

              <!-- Description -->
              <div class="mb-4">
                <label class="detail-label"> Description </label>

                <div class="detail-value description-box">
                    <%=showAnnouncements[0].description%>
                </div>
              </div>

              <!-- Buttons -->
              <div class="d-flex gap-3">
                <a href="/web/view/announcement/list" class="btn btn-secondary">
                  <i class="fa-solid fa-arrow-left me-2"></i>
                  Back to List
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
