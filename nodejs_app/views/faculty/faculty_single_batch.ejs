<!doctype html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Single Batch Details</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="/assets/css/faculty.css">
</head>

<body>
  <div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h3>Single Batch Details</h3>

      <a href="/web/faculty/batch/view" class="btn btn-secondary">
        <i class="fa-solid fa-arrow-left me-1"></i> Back
      </a>
    </div>

    <div class="card profile-card p-4">
      <div class="text-center mb-4">
        <img src="<%= singleBatch[0].facultyList.profileImage %>" class="profile-img" />
        <h4 class="mt-3">
          <%= singleBatch[0].userInfo.name%>
        </h4>
        <p class="text-muted">
          <%= singleBatch[0].departmentInfo.deptName %>
        </p>
      </div>

      <div class="row">
        <div class="col-md-6 mb-3">
          <div class="label">Email</div>
          <div class="value">
            <%= singleBatch[0].userInfo.email %>
          </div>
        </div>

        <% singleBatch.forEach( batch => { %>
          <div class="col-md-6 mb-3">
            <div class="label">Batch Name</div>
            <div class="value">
              <%= batch.batchName%>
            </div>
          </div>

          <div class="col-md-6 mb-3">
              <div class="label">Course Name</div>
              <div class="value">
                <%= batch.courseList.courseName %> years
              </div>
            </div>

            <div class="col-md-6 mb-3">
              <div class="label">Status</div>
              <div class="value">
                <span class="status-active">
                  <%= batch.status%>
                </span>
              </div>
            </div>


            <div class="col-md-6 mb-3">
              <div class="label">Start Date</div>
              <div class="value">
                <span class="status-active">
                  <%= new Date(batch.startDate).toDateString() %>
                </span>
              </div>
            </div>

            <div class="col-md-6 mb-3">
              <div class="label">End Date</div>
              <div class="value">
                <span class="status-active bg-danger">
                <%= new Date(batch.endDate).toDateString() %> 
                </span>
              </div>
            </div>

            <div class="col-12 mb-3">
              <div class="label">About</div>
              <div class="value">
                <%= batch.courseList.description %>
                
              </div>
            </div>

          <% }) %>
        
            
      </div>
    </div>
  </div>
</body>

</html>