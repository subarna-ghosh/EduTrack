<!doctype html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Single Batch Details</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="/assets/css/faculty.css">
  <link rel="stylesheet" href="/assets/css/style.css" />

  <style>
    .card {
      border-radius: 20px;
    }

    hr {
      opacity: .15;
    }
  </style>
</head>

<body>

  <div class="container-fluid">
    <div class="row">

      <!-- SIDEBAR -->
      <div class="col-lg-2 sidebar">
        <div class="logo"><i class="fa-solid fa-graduation-cap me-3"></i>Faculty Panel</div>

        <ul class="nav flex-column">
          <li>
            <a href="/web/view/faculty/dashboard" class="nav-link">
              <i class="fa-solid fa-chart-line"></i>
              Dashboard
            </a>
          </li>

          <li>
            <a href="/web/faculty/batch/view" class="nav-link active">
              <i class="fa-solid fa-users"></i>
              My Batches
            </a>
          </li>

          <li>
            <a href="/web/faculty/allproject/view" class="nav-link">
              <i class="fa-solid fa-code"></i>
              Projects
            </a>
          </li>

          <li>
            <a href="/web/view/coursematerial/list" class="nav-link">
              <i class="fa-solid fa-book-open"></i>
              Course Materials
            </a>
          </li>

          <li>
            <a href="/web/view/show/announcement" class="nav-link">
              <i class="fa-solid fa-bullhorn"></i>
              Announcements
            </a>
          </li>

          <li>
            <a href="/web/view/calender" class="nav-link">
              <i class="fa-solid fa-calendar"></i>
              Calender
            </a>
          </li>

          <li>
            <a href="/web/logout" class="nav-link">
              <i class="fa-solid fa-right-from-bracket"></i>
              Logout
            </a>
          </li>
        </ul>
      </div>

      <!-- MAIN CONTENT -->
      <div class="col-lg-10 main-content">

        <!-- TOP NAV -->
        <nav class="navbar navbar-expand-lg top-navbar">
          <div class="container-fluid">
            <h2 class="text-white mb-0">Batch</h2>

            <div class="ms-auto d-flex align-items-center gap-3">
              
              <button class="btn btn-light rounded-circle">
                <i class="fa-regular fa-moon"></i>
              </button>

              <button class="btn btn-light fw-semibold">
                <%= facultyProfile[0].userList.name %>
              </button>
            </div>
          </div>
        </nav>

        <!-- HEADER -->
        <div class="d-flex justify-content-between align-items-center mb-4 ms-4">
          <h2 class="fw-bold">Batch Details</h2>

          <a href="/web/faculty/batch/view" class="btn btn-secondary me-5">
            <i class="fa fa-arrow-left"></i> Back
          </a>
        </div>

        <!-- GET SINGLE BATCH (NO LOOP) -->
        <% const batch = singleBatch[0]; %>

        <!-- CARD -->
        <div class="card shadow border-0 rounded-4 ms-5" style="width: 90%;">
          <div class="card-body p-5">

            <!-- DEPARTMENT -->
            <div class="mb-4">
              <small class="text-muted fw-bold">Department Name</small>
              <h4><%= batch.departmentInfo.deptName %></h4>
            </div>

            <div class="row">

              <!-- LEFT SIDE -->
              <div class="col-lg-6">

                <div class="mb-4">
                  <small class="text-muted fw-bold">Course Name</small>
                  <h4><%= batch.courseList.courseName %></h4>
                </div>

                <div class="mb-4">
                  <small class="text-muted fw-bold">Start Date</small><br>
                  <span class="badge bg-success px-3 py-2">
                    <%= new Date(batch.startDate).toDateString() %>
                  </span>
                </div>

                <div class="mb-4">
                  <small class="text-muted fw-bold">Status</small><br>

                  <% if(batch.status === "active") { %>
                    <span class="badge bg-success px-3 py-2">Active</span>
                  <% } else { %>
                    <span class="badge bg-danger px-3 py-2">Inactive</span>
                  <% } %>

                </div>

              </div>

              <!-- RIGHT SIDE -->
              <div class="col-lg-6">

                <div class="mb-4">
                  <small class="text-muted fw-bold">Batch Name</small>
                  <h4><%= batch.batchName %></h4>
                </div>

                <div class="mb-4">
                  <small class="text-muted fw-bold">End Date</small><br>
                  <span class="badge bg-danger px-3 py-2">
                    <%= new Date(batch.endDate).toDateString() %>
                  </span>
                </div>

              </div>

            </div>

            <!-- STUDENTS TABLE -->
            <div class="mt-4">
              <h5 class="mb-3">Assigned Students</h5>

              <div class="table-responsive">
                <table class="table table-bordered table-hover">
                  <thead>
                    <tr>
                      <th>Sl.No</th>
                      <th>Name</th>
                      <th>Status</th>
                      <th>Action</th>
                    </tr>
                  </thead>

                  <tbody>
                    <% batch.studentInfo.forEach((student, index) => { %>
                      <tr>
                        <td><%= index + 1 %></td>
                        <td><%= student.name %></td>
                        <td>
                          <span class="badge bg-success">
                            <%= student.status %>
                          </span>
                        </td>
                        <td>
                          <span class="badge bg-primary">Submitted</span>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>

            </div>

          </div>
        </div>

      </div>
    </div>
  </div>

</body>
</html>