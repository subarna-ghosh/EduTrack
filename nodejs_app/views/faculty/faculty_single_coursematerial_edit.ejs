<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Edit Course Material</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
    <link rel="stylesheet" href="/assets/css/course.css" />

     <style>
        body {
            background: #f4f6f9;
        }

        .form-card {
            border: none;
            border-radius: 16px;
            box-shadow: 0 0.15rem 1.75rem rgba(58, 59, 69, 0.15);
        }

        .page-title {
            font-weight: 700;
            color: #343a40;
        }

        .form-label {
            font-weight: 600;
        }

        .image-preview {
            width: 130px;
            height: 130px;
            border: 2px dashed #ced4da;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            margin-bottom: 15px;
            background: #fff;
            position: relative;
        }

        .image-preview img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: none;
        }

        .image-preview i {
            font-size: 45px;
            color: #adb5bd;
            position: absolute;
        }

        textarea {
            resize: none;
        }
    </style>

</head>

<body>
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card form-card">
                    <!-- Header -->

                    <div class="card-header bg-white py-3">
                        <h3 class="page-title mb-0">Edit Course Material</h3>
                    </div>

                    <!-- Body -->

                    <% singleCourseMaterial.forEach(coursematerial => { %>

                        <div class="card-body p-4">
                            <form action="/web/faculty/coursematerial/update/<%= coursematerial._id %>" method="POST" enctype="multipart/form-data">

                                <input type="hidden" name="roleId" value="" />


                                <div class="mb-4 text-center">
                                    <div class="image-preview mx-auto">

                                        <!-- Show old image if exists -->
                                        <% if (coursematerial.materialImage) { %>
                                            <img id="previewImage" src="<%= coursematerial.materialImage %>"
                                                style="max-width:150px;" />
                                            <% } else { %>
                                                <i class="fa-solid fa-file"></i>
                                                <img id="previewImage" style="max-width:150px; display:none;" />
                                                <% } %>

                                    </div>

                                    <label class="form-label">Project Image</label>

                                    <input type="file" name="materialImage" class="form-control" accept="image/*"
                                        onchange="preview(event)" />
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Course Material Title</label>

                                    <input type="text" name="title" class="form-control"
                                        placeholder="Enter project title" required value="<%= coursematerial.title %>" />
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Course Material Description</label>

                                    <textarea name="description" class="form-control"
                                        placeholder="Enter Project Description" required
                                        rows="6"><%= coursematerial.description %></textarea>
                                </div>

                                <% }) %>

                                    <div class="d-flex gap-3">
                                        <button type="submit" class="btn btn-primary">
                                            <i class="fa-solid fa-user-plus me-2"></i>
                                            Update Course Material
                                        </button>

                                        <a href="/web/faculty/view/allcoursematerial" class="btn btn-secondary">
                                            <i class="fa-solid fa-arrow-left me-2"></i>
                                            Back
                                        </a>
                                    </div>
                            </form>
                        </div>

                </div>
            </div>
        </div>
    </div>
</body>

</html>