<!doctype html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Project List</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" rel="stylesheet" />

    <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js"></script>

    <link rel="stylesheet" href="/assets/css/style.css" />

    <link rel="stylesheet" href="/assets/css/faculty.css">


</head>

<body>

    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-2 sidebar">
                <div class="logo"><i class="fa-solid fa-graduation-cap me-3"></i>Faculty Panel</div>

                <ul class="nav flex-column">
                    <li>
                        <a href="/web/view/faculty/dashboard" class="nav-link">
                            <i class="fa-solid fa-chart-line"></i>
                            Dashboard
                        </a>
                    </li>

                    <li>
                        <a href="/web/faculty/batch/view" class="nav-link">
                            <i class="fa-solid fa-users"></i>
                            My Batches
                        </a>
                    </li>

                    <li>
                        <a href="/web/faculty/allproject/view" class="nav-link active">
                            <i class="fa-solid fa-code"></i>
                            Projects
                        </a>
                    </li>

                    <li>
                        <a href="/web/view/coursematerial/list" class="nav-link">
                            <i class="fa-solid fa-book-open"></i>
                            Course Materials
                        </a>
                    </li>

                    <li>
                        <a href="/web/view/show/announcement" class="nav-link">
                            <i class="fa-solid fa-bullhorn"></i>
                            Announcements
                        </a>
                    </li>
                    <li>
                        <a href="/web/view/calender" class="nav-link">
                            <i class="fa-solid fa-calendar"></i>
                            Calender
                        </a>
                    </li>

                    <li>
                        <a href="/web/logout" class="nav-link">
                            <i class="fa-solid fa-right-from-bracket"></i>
                            Logout
                        </a>
                    </li>
                </ul>
            </div>

            <!-- <div class="page-wrapper"> -->
            <div class="col-lg-10 main-content">
                <nav class="navbar navbar-expand-lg top-navbar">
                    <div class="container-fluid">

                        <h2 class="text-white mb-0">Project</h2>

                        <div class="ms-auto d-flex align-items-center gap-3">
                            <!-- <button class="btn btn-light rounded-circle"> -->
                            <!-- <i class="fa-regular fa-bell"></i> -->
                            <!-- </button> -->

                            <button class="btn btn-light rounded-circle">
                                <i class="fa-regular fa-moon"></i>
                            </button>

                            <button class="btn btn-light fw-semibold">
                                <%= facultyProfile[0].userList.name %>
                            </button>
                        </div>

                    </div>
                </nav>

                <div class="faculty-card">
                    <div class="top-bar">
                        <!-- <input type="text" class="form-control search-box" placeholder="Search Faculty..." /> -->

                        <div class="d-flex w-100 justify-content-end me-3 gap-3">
                            <!-- Add Department Button -->


                            <a href="/web/faculty/project/view" class="btn btn-success">
                                + Add Project
                            </a>

                            <a href="/web/view/faculty/dashboard" class="btn btn-secondary">
                                ← Back To Dashboard
                            </a> 
                        </div>
                    </div>

                    <!-- connect-flash -->
                    <% if (success.length> 0) { %>
                        <div id="successAlert" class="alert alert-info">
                            <%= success[0] %>
                        </div>
                        <% } %>

                            <% if (error.length> 0) { %>
                                <div id="successAlert" class="alert alert-danger">
                                    <%= error[0] %>
                                </div>
                                <% } %>

                                    <div class="table-responsive">
                                        <table class="table table-bordered table-hover">
                                            <thead>
                                                <tr>
                                                    <th>Sl.no</th>
                                                    <th>Title</th>
                                                    <th>Description</th>
                                                    <th>Project Pdf</th>
                                                    <th>Batch</th>

                                                    <th>StartDate</th>
                                                    <th>DueDate</th>
                                                    <th>Status</th>

                                                    <th width="180">Action</th>
                                                </tr>
                                            </thead>

                                            <tbody>
                                                <% if(getProjectInfo.length==0) { %>
                                                    <tr>
                                                        <td colspan="9" style="text-align: center;">
                                                            ---------- No Data Found -----------
                                                        </td>
                                                    </tr>
                                                    <% } %>

                                                        <% getProjectInfo.forEach((project, index)=>{%>
                                                            <tr>
                                                                <td>
                                                                    <%= index+1 %>
                                                                </td>
                                                                <td>
                                                                    <%= project.title %>
                                                                </td>
                                                                <td>
                                                                    <%- project.description %>
                                                                </td>

                                                                <td><img src="<%= project.projectImage %>"
                                                                        class="project-img" /></td>
                                                                <td>
                                                                    <%= project.batchInfo.batchName %>
                                                                </td>

                                                                <td>
                                                                    <%= new
                                                                        Date(project.startDate).toLocaleDateString("en-GB")
                                                                        %>
                                                                </td>
                                                                <td>
                                                                    <%= new
                                                                        Date(project.dueDate).toLocaleDateString("en-GB")
                                                                        %>
                                                                </td>

                                                                <td>
                                                                    <span class="status-active">
                                                                        <%= project.status %>
                                                                    </span>
                                                                </td>
                                                                <td>
                                                                    <div class="action-btns ms-4">
                                                                        <a href="/web/faculty/singleproject/view/<%= project._id %>"
                                                                            class="btn btn-sm btn-info"><i
                                                                                class="fa-solid fa-eye"></i></a>
                                                                        <a href="/web/faculty/edit/view/<%= project._id %>"
                                                                            class="btn btn-sm btn-warning"><i
                                                                                class="fa-solid fa-pen-to-square"></i></a>
                                                                        <a href="/web/project/delete/<%= project._id %>"
                                                                            class="btn btn-sm btn-danger"><i
                                                                                class="fa-solid fa-trash"></i></a>
                                                                    </div>
                                                                </td>
                                                            </tr>
                                                            <%})%>
                                            </tbody>
                                        </table>
                                    </div>

                                    <div class="pagination-wrapper" style="cursor: pointer;">

                                        <nav>
                                            <ul class="pagination">

                                                <!-- Previous -->
                                                <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                                                    <a class="page-link" href="?page=<%= currentPage - 1 %>">
                                                        Previous
                                                    </a>
                                                </li>

                                                <!-- Page Numbers -->
                                                <% for(let i=1; i <=totalPages; i++) { %>
                                                    <li class="page-item <%= i === currentPage ? 'active' : '' %>">
                                                        <a class="page-link" href="?page=<%= i %>">
                                                            <%= i %>
                                                        </a>
                                                    </li>
                                                    <% } %>

                                                        <!-- Next -->
                                                        <li
                                                            class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                                                            <a class="page-link" href="?page=<%= currentPage + 1 %>">
                                                                Next
                                                            </a>
                                                        </li>

                                            </ul>
                                        </nav>

                                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- modal -->
    <div class="modal fade" id="addDeptModal" tabindex="-1" aria-labelledby="addDeptModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <!-- Header -->
                <div class="modal-header">
                    <h5 class="modal-title" id="addDeptModalLabel">Add Department</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <!-- Body -->
                <div class="modal-body">
                    <form id="deptForm" action="/web/save/department" method="post">
                        <div class="mb-3">
                            <label class="form-label">Department Name</label>
                            <input type="text" class="form-control" name="deptName"
                                placeholder="Enter department name" />
                        </div>

                        <button type="submit" class="btn btn-primary">
                            Save Department
                        </button>
                    </form>
                </div>

                <!-- Footer -->
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        Cancel
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        setTimeout(() => {
            const alert = document.getElementById("successAlert");
            if (alert) {
                alert.remove();
            }
        }, 1000); // 1 seconds
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"></script>
</body>

</html>