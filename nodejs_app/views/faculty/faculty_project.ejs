<!doctype html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Project List</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous" />
    <link rel="stylesheet" href="/assets/css/faculty.css">
</head>

<body>
    <div class="page-wrapper">
        <h2 class="page-title">Project List</h2>

        <div class="faculty-card">
            <div class="top-bar">
                <input type="text" class="form-control search-box" placeholder="Search Faculty..." />

                <div class="d-flex gap-2">
                    <!-- Add Department Button -->


                    <a href="/web/faculty/project/view" class="btn btn-success">
                        + Add Project
                    </a>

                    <a href="/web/view/faculty/dashboard" class="btn btn-secondary">
                        ← Back to Dashboard
                    </a>
                </div>
            </div>

            <!-- connect-flash -->
            <% if (success.length> 0) { %>
                <div id="successAlert" class="alert alert-info">
                    <%= success[0] %>
                </div>
                <% } %>

                    <% if (error.length> 0) { %>
                        <div id="successAlert" class="alert alert-danger">
                            <%= error[0] %>
                        </div>
                        <% } %>

                            <div class="table-responsive">
                                <table class="table table-bordered table-hover">
                                    <thead>
                                        <tr>
                                            <th>Sl.no</th>
                                            <th>Title</th>
                                            <th>Description</th>
                                            <th>Project Pdf</th>
                                            <th>batchId</th>
                                           
                                            <th>startDate</th>
                                            <th>dueDate</th>
                                            <th>Status</th>
                                            
                                            <th width="180">Action</th>
                                        </tr>
                                    </thead>

                                    <tbody>
                                        <% getProjectInfo.forEach((project, index)=>{%>
                                            <tr>
                                                <td>
                                                    <%= index+1 %>
                                                </td>
                                                <td>
                                                    <%= project.title %>
                                                </td>
                                      <td>
                                                    <%- project.description %>
                                                </td>
                                                
                                                <td><img src="<%= project.projectImage %>" class="project-img" /></td>
                                                <td>
                                                    <%= project.batchInfo.batchName %>
                                                </td>
                                                
                                                <td>
                                                    <%= new Date(project.startDate).toLocaleDateString("en-GB") %>
                                                </td>
                                                <td>
                                                    <%= new Date(project.dueDate).toLocaleDateString("en-GB") %>
                                                </td>

                                                <td>
                                                    <span class="status-active">
                                                        <%= project.status %>
                                                    </span>
                                                </td>
                                                <td>
                                                    <div class="action-btns">
                                                        <a href="/web/faculty/singleproject/view/<%= project._id %>"
                                                            class="btn btn-sm btn-info">View</a>
                                                        <a href="/web/faculty/edit/view/<%= project._id %>"
                                                            class="btn btn-sm btn-warning">Edit</a>
                                                        <a href="/web/delete/faculty/<%= project._id %>"
                                                            class="btn btn-sm btn-danger">Delete</a>
                                                    </div>
                                                </td>
                                            </tr>
                                            <%})%>
                                    </tbody>
                                </table>
                            </div>

                            <div class="pagination-wrapper" style="cursor: pointer;">

                                <nav>
                                    <ul class="pagination">

                                        <!-- Previous -->
                                        <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                                            <a class="page-link" href="?page=<%= currentPage - 1 %>">
                                                Previous
                                            </a>
                                        </li>

                                        <!-- Page Numbers -->
                                        <% for(let i=1; i <= totalPages; i++) { %>
                                            <li class="page-item <%= i === currentPage ? 'active' : '' %>">
                                                <a class="page-link" href="?page=<%= i %>">
                                                    <%= i %>
                                                </a>
                                            </li>
                                            <% } %>

                                                <!-- Next -->
                                                <li
                                                    class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                                                    <a class="page-link" href="?page=<%= currentPage + 1 %>">
                                                        Next
                                                    </a>
                                                </li>

                                    </ul>
                                </nav>

                            </div>
        </div>
    </div>
    <!-- modal -->
    <div class="modal fade" id="addDeptModal" tabindex="-1" aria-labelledby="addDeptModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <!-- Header -->
                <div class="modal-header">
                    <h5 class="modal-title" id="addDeptModalLabel">Add Department</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <!-- Body -->
                <div class="modal-body">
                    <form id="deptForm" action="/web/save/department" method="post">
                        <div class="mb-3">
                            <label class="form-label">Department Name</label>
                            <input type="text" class="form-control" name="deptName"
                                placeholder="Enter department name" />
                        </div>

                        <button type="submit" class="btn btn-primary">
                            Save Department
                        </button>
                    </form>
                </div>

                <!-- Footer -->
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        Cancel
                    </button>
                </div>
            </div>
        </div>
    </div>
    <script>
        setTimeout(() => {
            const alert = document.getElementById("successAlert");
            if (alert) {
                alert.remove();
            }
        }, 1000); // 1 seconds
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"></script>
</body>

</html>