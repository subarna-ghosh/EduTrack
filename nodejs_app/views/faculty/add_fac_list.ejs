                <td>
                  <span class="status-active"> Active </span>
                </td>
                <td>
                  <div class="action-btns">
                    <button class="btn btn-sm btn-info">View</button>

                    <button class="btn btn-sm btn-warning">Edit</button>

                    <button class="btn btn-sm btn-danger">Delete</button>
                  </div>
                </td>
              </tr>

              <tr>
                <td>2</td>
