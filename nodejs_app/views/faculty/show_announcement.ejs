<!doctype html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>faculty Announcements</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
  <link rel="stylesheet" href="/assets/css/show_announcement_student.css">

  <link rel="stylesheet" href="/assets/css/style.css" />
</head>

<body>

  <div class="container-fluid">
    <div class="row">
      <div class="col-lg-2 sidebar">
        <div class="logo"><i class="fa-solid fa-graduation-cap me-3"></i>Faculty Panel</div>

        <ul class="nav flex-column">
          <li>
            <a href="/web/view/faculty/dashboard" class="nav-link">
              <i class="fa-solid fa-chart-line"></i>
              Dashboard
            </a>
          </li>

          <li>
            <a href="/web/faculty/batch/view" class="nav-link">
              <i class="fa-solid fa-users"></i>
              My Batches
            </a>
          </li>

          <li>
            <a href="/web/faculty/allproject/view" class="nav-link">
              <i class="fa-solid fa-code"></i>
              Projects
            </a>
          </li>

          <li>
            <a href="/web/view/coursematerial/list" class="nav-link">
              <i class="fa-solid fa-book-open"></i>
              Course Materials
            </a>
          </li>

          <li>
            <a href="/web/view/show/announcement" class="nav-link active">
              <i class="fa-solid fa-bullhorn"></i>
              Announcements
            </a>
          </li>
          <li>
            <a href="/web/view/calender" class="nav-link">
              <i class="fa-solid fa-calendar"></i>
              Calender
            </a>
          </li>

          <li>
            <a href="/web/logout" class="nav-link">
              <i class="fa-solid fa-right-from-bracket"></i>
              Logout
            </a>
          </li>
        </ul>
      </div>
      <div class="col-lg-10 main-content">
        <nav class="navbar navbar-expand-lg top-navbar">
          <div class="container-fluid">
            <h2 class="text-white mb-0 ms-5">Announcement</h2>

            <div class="ms-auto d-flex align-items-center gap-3">
              <!-- <button class="btn btn-light rounded-circle"> -->
              <!-- <i class="fa-regular fa-bell"></i> -->
              <!-- </button> -->

              <button class="btn btn-light rounded-circle">
                <i class="fa-regular fa-moon"></i>
              </button>

              <button class="btn btn-light fw-semibold me-5">
                 <%= facultyProfile[0].userList.name %>
              </button>
            </div>


          </div>
        </nav>
        <div class="container py-5">
          <!-- Header -->

          <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
              <h2 class="page-title mb-1">Announcements</h2>
              <p class="text-muted mb-0">
                Stay updated with the latest academy notices and updates.
              </p>
            </div>

            <a href="/web/view/faculty/dashboard" class="btn btn-secondary">
              ← Back to Dashboard
            </a>
          </div>

          <!-- Upcoming -->

          <h4 class="section-title">Upcoming Announcements</h4>

          <div class="empty-box mb-5">
            <i class="fa-solid fa-bullhorn"></i>

            <h5>No urgent announcements</h5>

            <p class="text-muted mb-0">You're all caught up.</p>
          </div>

          <!-- All Announcements -->

          <h4 class="section-title">All Announcements</h4>

          <!-- Card 1 -->
          <% announcementsMade.forEach((val)=>{ %>
            <div class="card announcement-card">
              <div class="d-flex">
                <div class="date-box">
                  <h2>
                    <%= new Date(val.createdAt).toLocaleDateString("en-GB", { day: "numeric" }) %>
                  </h2>
                  <span>
                    <%= new Date(val.createdAt).toLocaleDateString("en-GB", { month: "short" }).toUpperCase() %>
                  </span>
                </div>

                <div class="card-content flex-grow-1">
                  <div class="d-flex justify-content-between">
                    <h5 class="announcement-title">
                      <%= val.title %>
                    </h5>

                    <span class="badge bg-danger"> Important </span>
                  </div>

                  <p class="announcement-desc">
                    <%= val.description %>
                  </p>

                  <div class="card-footer-custom">
                    <span class="location">
                      <i class="fa-regular fa-calendar me-2"></i>
                      <%= new Date(val.createdAt).toLocaleDateString("en-GB") %>
                    </span>
                  </div>
                </div>
              </div>
            </div>
          <% }) %>

        </div>
      </div>
    </div>
  </div>

</body>

</html>