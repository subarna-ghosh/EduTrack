        <!-- ASSIGNED BATCHES -->

        <div class="dashboard-card mb-4 ms-5">
          <div class="d-flex justify-content-between mb-3">
            <h5>Assigned Batches</h5>

            
          </div>

          <% if (findBatch && findBatch.length> 0) { %>

        <table class="table">
          <thead>
            <tr>
              <th>Batch Name</th>
              <th>Course</th>
              
              <th>Start Date</th>
              <th>End Date</th>
              <th>Status</th>
              <th>Action</th>
            </tr>
          </thead>

          <tbody>
            <% findBatch.forEach(batch => { %>
              <tr>
                <td>
                  <%= batch.batchName %>
                </td>

                <td>
                  <%= batch.courseList ? batch.courseList.courseName : "N/A" %>
                </td>

                
                <td>
                  <%= batch.startDate ? new Date(batch.startDate).toLocaleDateString() : "-" %>
                </td>

                <td>
                  <%= batch.endDate ? new Date(batch.endDate).toLocaleDateString() : "-" %>
                </td>

                <td>
                 <span class="badge <%= batch.status === 'upcoming' ? 'bg-secondary' : 'bg-success' %>">
    <%= batch.status %>
</span>
                </td>

                <td>
                  <a href="/web/faculty/singlebatch/view/<%= batch._id %>" class="btn btn-primary rounded-2 text-white">
                    View Details
                  </a>
                </td>
              </tr>
              <% }) %>
          </tbody>
        </table>

        <% } else { %>

          <div class="no-data">
            No batches assigned to you.
          </div>

          <% } %>
        </div>

