<!doctype html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Faculty Dashboard</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" rel="stylesheet" />

  <link rel="stylesheet" href="style.css" />
  <style>
    body {
      background: #f5f7fb;
      font-family: Arial, sans-serif;
    }

    .sidebar {
      min-height: 100vh;
      background: #ffffff;
      border-right: 1px solid #e5e7eb;
      padding: 25px;
    }

    .logo {
      font-size: 24px;
      font-weight: 700;
      margin-bottom: 40px;
    }

    .nav-link {
      color: #64748b;
      padding: 12px;
      border-radius: 12px;
      margin-bottom: 8px;
    }

    .nav-link:hover,
    .nav-link.active {
      background: #eef4ff;
      color: #2563eb;
    }

    .nav-link i {
      margin-right: 10px;
    }

    .main-content {
      padding: 30px;
    }

    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 30px;
    }

    .search-box {
      width: 50%;
      height: 50px;
    }

    .top-actions {
      display: flex;
      align-items: center;
      gap: 15px;
    }

    .icon-btn {
      width: 45px;
      height: 45px;
      border: none;
      background: #fff;
      border-radius: 12px;
    }

    .profile {
      background: #fff;
      padding: 12px 20px;
      border-radius: 12px;
      font-weight: 600;
    }

    .page-title {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 30px;
    }

    .page-title p {
      color: #64748b;
    }

    .stats-card {
      background: #fff;
      padding: 25px;
      border-radius: 18px;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    }

    .stats-card h6 {
      color: #64748b;
    }

    .stats-card h2 {
      font-weight: 700;
      margin-top: 10px;
    }

    .blue {
      border-left: 5px solid #2563eb;
    }

    .green {
      border-left: 5px solid #16a34a;
    }

    .orange {
      border-left: 5px solid #f59e0b;
    }

    .red {
      border-left: 5px solid #ef4444;
    }

    .dashboard-card {
      background: #fff;
      border-radius: 18px;
      padding: 25px;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    }

    .attendance {
      font-size: 60px;
      font-weight: 700;
      color: #16a34a;
    }

    .announcement {
      padding: 15px 0;
      border-bottom: 1px solid #e5e7eb;
    }

    .table {
      margin-bottom: 0;
    }
  </style>
</head>

<body>
  <div class="container-fluid">
    <div class="row">
      <!-- SIDEBAR -->

      <div class="col-lg-2 sidebar">
        <div class="logo">Faculty Panel</div>

        <ul class="nav flex-column">
          <li>
            <a href="/web/view/faculty/dashboard" class="nav-link active">
              <i class="fa-solid fa-chart-line"></i>
              Dashboard
            </a>
          </li>

          <li>
            <a href="/web/faculty/batch/view" class="nav-link">
              <i class="fa-solid fa-users"></i>
              My Batches
            </a>
          </li>

          <li>
            <a href="/web/faculty/allproject/view" class="nav-link">
              <i class="fa-solid fa-code"></i>
              Projects
            </a>
          </li>

          <li>
            <a href="/web/faculty/view/allcoursematerial" class="nav-link">
              <i class="fa-solid fa-book-open"></i>
              Course Materials
            </a>
          </li>

          <li>
            <a href="#" class="nav-link">
              <i class="fa-solid fa-bullhorn"></i>
              Announcements
            </a>
          </li>

          <li>
            <a href="/web/logout" class="nav-link">
              <i class="fa-solid fa-right-from-bracket"></i>
              Logout
            </a>
          </li>
        </ul>
      </div>

      <!-- MAIN CONTENT -->

      <div class="col-lg-10 main-content">
        <!-- TOPBAR -->

        <div class="topbar">
          <input type="text" class="form-control search-box" placeholder="Search batches, students..." />

          <div class="top-actions">
            <button class="icon-btn">
              <i class="fa-regular fa-bell"></i>
            </button>

            <button class="icon-btn">
              <i class="fa-regular fa-moon"></i>
            </button>

            <div class="profile">Faculty</div>
          </div>
        </div>

        <!-- PAGE TITLE -->

        <div class="page-title">
          <div>
            <h2>Welcome Back, Faculty</h2>
            <p>Manage your classes, batches and students.</p>
          </div>
          <a href="/web/view/faculty/profile/<%- profile._id %>">
            <button class="btn btn-primary">My Profile</button>
          </a>
        </div>

        <!-- STATS -->

        <div class="row g-4 mb-4">
          <div class="col-lg-3 col-md-6">
            <div class="stats-card blue">
              <h6>Assigned Batches</h6>
              <h2>8</h2>
            </div>
          </div>

          <div class="col-lg-3 col-md-6">
            <div class="stats-card green">
              <h6>Today's Classes</h6>
              <h2>4</h2>
            </div>
          </div>

          <div class="col-lg-3 col-md-6">
            <div class="stats-card orange">
              <h6>Total Students</h6>
              <h2>210</h2>
            </div>
          </div>

          <div class="col-lg-3 col-md-6">
            <div class="stats-card red">
              <h6>Pending Reviews</h6>
              <h2>12</h2>
            </div>
          </div>
        </div>

        <!-- SCHEDULE + ATTENDANCE -->

        <!-- <div class="row g-4 mb-4">
          <div class="col-lg-8">
