<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Faculty Profile</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
      rel="stylesheet"
    />

    <link rel="stylesheet" href="/assets/css/style.css" />
    <link rel="stylesheet" href="/assets/css/faculty.css">
  </head>

  <body>
    <div class="container-fluid">
    <div class="row">
      <div class="col-lg-2 sidebar">
        <div class="logo"><i class="fa-solid fa-graduation-cap me-3"></i>Faculty Panel</div>

        <ul class="nav flex-column">
          <li>
            <a href="/web/view/faculty/dashboard" class="nav-link active">
              <i class="fa-solid fa-chart-line"></i>
              Dashboard
            </a>
          </li>

          <li>
            <a href="/web/faculty/batch/view" class="nav-link">
              <i class="fa-solid fa-users"></i>
              My Batches
            </a>
          </li>

          <li>
            <a href="/web/faculty/allproject/view" class="nav-link">
              <i class="fa-solid fa-code"></i>
              Projects
            </a>
          </li>

          <li>
            <a href="/web/view/coursematerial/list" class="nav-link">
              <i class="fa-solid fa-book-open"></i>
              Course Materials
            </a>
          </li>

          <li>
            <a href="/web/view/show/announcement" class="nav-link">
              <i class="fa-solid fa-bullhorn"></i>
              Announcements
            </a>
          </li>
          <li>
            <a href="/web/view/calender" class="nav-link">
              <i class="fa-solid fa-calendar"></i>
              Calender
            </a>
          </li>

          <li>
            <a href="/web/logout" class="nav-link">
              <i class="fa-solid fa-right-from-bracket"></i>
              Logout
            </a>
          </li>
        </ul>
      </div>

      <div class="col-lg-10 main-content">
        
        <nav class="navbar navbar-expand-lg top-navbar">
          <div class="container-fluid">

            <h2 class="text-white mb-0">Profile</h2>

            <div class="ms-auto d-flex align-items-center gap-3">
              <!-- <button class="btn btn-light rounded-circle"> -->
              <!-- <i class="fa-regular fa-bell"></i> -->
              <!-- </button> -->

              <button class="btn btn-light rounded-circle">
                <i class="fa-regular fa-moon"></i>
              </button>

              <button class="btn btn-light fw-semibold">
                <%= showFacultyProfile[0].userInfo.name %>
              </button>
            </div>

          </div>
        </nav>
        <div class="container py-3">
          <div class="d-flex justify-content-between align-items-center mb-4">
            <h3>Personal Information</h3>

            <a href="/web/view/faculty/dashboard" class="btn btn-secondary">
              <i class="fa-solid fa-arrow-left me-1"></i> Back
            </a>
          </div>
      </div>
      <div class="card profile-card p-4 m-5">
        <div class="text-center mb-4">
          <img src="<%=showFacultyProfile[0].profileImage%>" class="profile-img" />
          <h4 class="mt-3"><%=showFacultyProfile[0].userInfo.name%></h4>
          <!-- <p class="text-muted"></p> -->
        </div>

        <div class="row">
          

          <div class="col-md-6 mb-3">
            <div class="label">Email : <span class="value"><%=showFacultyProfile[0].userInfo.email%></span></div>
            <!-- <div class="value"></div> -->
          </div>

          <div class="col-md-6 mb-3">
            <div class="label">Phone : <span class="value"><%=showFacultyProfile[0].phone%></span></div>
            <!-- <div class="value"></div> -->
          </div>
          <div class="col-md-6 mb-3">
            <div class="label">Department Name : <span class="value"><%=showFacultyProfile[0].deptInfo.deptName%></span></div>
            <!-- <div class="value"></div> -->
          </div>

          <div class="col-md-6 mb-3">
            <div class="label">Experience : <span class="value"><%=showFacultyProfile[0].experience%> years</span></div>
            <!-- <div class="value"></div> -->
          </div>

          <div class="col-md-6 mb-3">
            <div class="label">Status : <span class="status-active"><%=showFacultyProfile[0].status%></span></div>
            <div class="value">
              <!-- <span class="status-active"></span> -->
            </div>
          </div>

          <!-- <div class="col-12 mb-3">
            <div class="label">About</div>
            <div class="value">
              Experienced faculty in web development specializing in MERN stack,
              frontend architecture, and UI/UX systems.
            </div>
          </div> -->
        </div>
      </div>
    </div>
  </body>
</html>
