<!doctype html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Calendar</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" rel="stylesheet" />

  <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js"></script>

  
  <link rel="stylesheet" href="/assets/css/style.css" />
  
</head>

<body>
  <div class="container-fluid">
    <div class="row">
      <!-- SIDEBAR -->

      <div class="col-lg-2 sidebar">
        <div class="logo"><i class="fa-solid fa-graduation-cap me-3"></i>Faculty Panel</div>

        <ul class="nav flex-column">
          <li>
            <a href="/web/view/faculty/dashboard" class="nav-link">
              <i class="fa-solid fa-chart-line"></i>
              Dashboard
            </a>
          </li>

          <li>
            <a href="/web/faculty/batch/view" class="nav-link">
              <i class="fa-solid fa-users"></i>
              My Batches
            </a>
          </li>

          <li>
            <a href="/web/faculty/allproject/view" class="nav-link">
              <i class="fa-solid fa-code"></i>
              Projects
            </a>
          </li>

          <li>
            <a href="/web/view/coursematerial/list" class="nav-link">
              <i class="fa-solid fa-book-open"></i>
              Course Materials
            </a>
          </li>

          <li>
            <a href="/web/view/show/announcement" class="nav-link">
              <i class="fa-solid fa-bullhorn"></i>
              Announcements
            </a>
          </li>

           <li>
            <a href="/web/view/calender" class="nav-link active">
              <i class="fa-solid fa-calendar"></i>
              Calender
            </a>
          </li>

          <li>
            <a href="/web/logout" class="nav-link">
              <i class="fa-solid fa-right-from-bracket"></i>
              Logout
            </a>
          </li>
        </ul>
      </div>

      <div class="col-lg-10 main-content">
        <nav class="navbar navbar-expand-lg top-navbar">
          <div class="container-fluid">
            <h2 class="text-white mb-0 ms-5">Calendar</h2>

            <div class="ms-auto d-flex align-items-center gap-3">
              <!-- <button class="btn btn-light rounded-circle"> -->
              <!-- <i class="fa-regular fa-bell"></i> -->
              <!-- </button> -->

              <button class="btn btn-light rounded-circle">
                <i class="fa-regular fa-moon"></i>
              </button>

              <button class="btn btn-light fw-semibold me-5">
                <%= facultyProfile[0].userList.name %>
              </button>
            </div>


          </div>
        </nav>
      <!-- MAIN CONTENT -->

      <div class="col-lg-10 main-content ms-5 mt-5">
        <!-- TOPBAR -->
          <div class="calendardiv">
             <div id="calendar"></div>
          </div>

        </div>
      </div>
      
    </div>
    
  </div>

  
  <script>
 document.addEventListener('DOMContentLoaded', function () {
  var calendarEl = document.getElementById('calendar');

  var calendar = new FullCalendar.Calendar(calendarEl, {
    
    initialView: 'dayGridMonth',
    eventTextColor: '#495057',
    height: 600,
    events: [
      
      // {
      //   title: 'Meeting',
      //   start: '2026-06-21'
      // },
      // {
      //   title: 'Exam',
      //   start: '2026-06-25'
      // }
    ]
  });

  calendar.render();
});
</script>

</body>

</html>