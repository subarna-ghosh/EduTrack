<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Add Project</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />

    <style>
        body {
            background: #f4f6f9;
        }

        .form-card {
            border: none;
            border-radius: 16px;
            box-shadow: 0 0.15rem 1.75rem rgba(58, 59, 69, 0.15);
        }

        .page-title {
            font-weight: 700;
            color: #343a40;
        }

        .form-label {
            font-weight: 600;
        }

        .image-preview {
            width: 130px;
            height: 130px;
            border: 2px dashed #ced4da;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            margin-bottom: 15px;
            background: #fff;
            position: relative;
        }

        .image-preview img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: none;
        }

        .image-preview i {
            font-size: 45px;
            color: #adb5bd;
            position: absolute;
        }

        textarea {
            resize: none;
        }
    </style>
</head>

<body>
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card form-card">
                    <!-- Header -->

                    <div class="card-header bg-white py-3">
                        <h3 class="page-title mb-0">Add Project</h3>
                    </div>

                    <!-- Body -->

                    <div class="card-body p-4">
                        <form action="/web/faculty/project/create" method="POST" enctype="multipart/form-data">
                            <!-- Hidden Faculty Role -->

                            <input type="hidden" name="roleId" value="" />

                            <!-- Project pdf -->

                            <div class="mb-4 text-center">
                                <div class="image-preview mx-auto">
                                    <i class="fa-solid fa-file"></i>

                                    <img id="previewImage" />
                                </div>

                                <label class="form-label"> Project pdf </label>

                                <input type="file" name="projectImage" class="form-control" accept="image/*"
                                    onchange="preview(event)" />
                            </div>

                            <!-- Faculty Name -->

                            <div class="mb-3">
                                <label class="form-label"> Faculty Name </label>

                                <input type="text" name="name" class="form-control" placeholder="Enter faculty name"
                                    value="<%= faculty[0].userInfo ? faculty[0].userInfo.name : '' %>" required />
                            </div>

                            <!-- Project Title -->

                            <div class="mb-3">
                                <label class="form-label"> Project Title </label>

                                <input type="text" name="title" class="form-control" placeholder="Enter project title"
                                    required />
                            </div>

                            <!-- Description -->

                            <div class="mb-3">
                                <label class="form-label"> Project Description </label>

                                <textarea name="description" class="form-control"
                                    placeholder="Enter Project Description" required rows="6"></textarea>
                            </div>

                            <!-- Address -->
                            <!-- 
                            <div class="mb-3">
                                <label class="form-label"> Address </label>

                                <textarea name="address" rows="3" class="form-control" placeholder="Enter address"
                                    required></textarea>
                            </div> -->

                            <!-- Department -->

                            <div class="mb-3">
                                <label class="form-label"> Department </label>

                                <select name="department" class="form-select" required>
                                    <option value="">Select Department</option>

                                    <% showAllBatch.forEach(course=> { %>
                                        <option value="<%= course._id %>">
                                            <%= course.courseInfo.courseName %>
                                        </option>
                                        <% }) %>
                                </select>

                            </div>
                            <div class="mb-3">
                                <label class="form-label"> Batch Name </label>

                                <select name="batchId" class="form-select" required>
                                    <option value="">Select Batch</option>

                                    <% showAllBatch.forEach(batch=> { %>
                                        <option value="<%= batch._id %>">
                                            <%= batch.batchName %>
                                        </option>
                                        <% }) %>

                                </select>

                            </div>

                            <!-- dueDate -->

                            <div class="mb-3">
                                <label class="form-label"> Deadline </label>

                                <input type="date" name="dueDate" class="form-control" required />
                            </div>

                            <!-- Experience -->

                            <!-- <div class="mb-3">
                                <label class="form-label"> Experience (Years) </label>

                                <input type="number" name="experience" class="form-control"
                                    placeholder="Enter experience" min="0" required />
                            </div> -->

                            <!-- Status -->

                            <div class="mb-4">
                                <label class="form-label"> Status </label>

                                <select name="status" class="form-select">
                                    <option value="active">Active</option>

                                    <option value="closed">Closed</option>
                                </select>
                            </div>

                            <!-- Buttons -->

                            <div class="d-flex gap-3">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fa-solid fa-user-plus me-2"></i>
                                    Add Project
                                </button>

                                <a href="/web/view/add/faculty/list" class="btn btn-secondary">
                                    <i class="fa-solid fa-arrow-left me-2"></i>
                                    Back
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        function preview(event) {
            const img = document.getElementById("previewImage");

            img.src = URL.createObjectURL(event.target.files[0]);

            img.style.display = "block";

            document.querySelector(".image-preview i").style.display = "none";
        }
    </script>
</body>

</html>